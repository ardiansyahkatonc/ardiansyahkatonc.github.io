---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { Section } from '../../components/ui/section';
import { Container } from '../../components/ui/container';
import { Card } from '../../components/ui/card';
import { Badge } from '../../components/ui/badge';
import ARIADashboard from '../../components/ui/mockup/ARIADashboard.astro';
import ExecutiveWorkflow from '../../components/sections/ExecutiveWorkflow.astro';
import Logo from '../../components/common/Logo.astro';
import { getLangFromUrl, useTranslations } from '../../i18n';

export function getStaticPaths() {
  return [{ params: { lang: 'id' } }, { params: { lang: 'en' } }];
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const capabilities = ['meeting', 'document', 'knowledge', 'workspace'] as const;
const capIcons: Record<string, string> = {
  meeting: '◎',
  document: '◈',
  knowledge: '▣',
  workspace: '⬡',
};

const useCases = ['1', '2', '3', '4'] as const;
const ucIcons: Record<string, string> = {
  '1': '<rect x="4" y="2.5" width="12" height="15" rx="1.5"/><path d="M7 6.5h6M7 9.5h6M7 12.5h4"/>',
  '2': '<path d="M4 4.5A1.5 1.5 0 015.5 3H16v11.5H5.5A1.5 1.5 0 004 16z"/><path d="M4 16a1.5 1.5 0 011.5-1.5H16V17H5.5A1.5 1.5 0 014 15.5"/>',
  '3': '<path d="M10 2.5l-1 6h4l-3 9 1-7H7z"/>',
  '4': '<path d="M10 2.5l6 2.5v4c0 3.5-2.4 6.6-6 7.5-3.6-.9-6-4-6-7.5V5z"/><path d="M7.5 10l2 2 3.5-4"/>',
};

const metrics = ['1', '2', '3'] as const;
---

<BaseLayout title={t('meta.aria.title')} description={t('meta.aria.desc')}>

  {/* A. Hero */}
  <Section type="hero" aria-labelledby="aria-hero-heading" class="aria-hero">
    <Container size="lg" class="center-container">
      <Logo brand="aria" size="lg" class="aria-hero-logo" alt="ARIA" />
      <div class="aria-badges">
        <Badge variant="primary">{t('aria.badge1')}</Badge>
        <Badge variant="neutral">{t('aria.badge2')}</Badge>
      </div>
      <h1 id="aria-hero-heading" class="display-xl text-center">{t('aria.h1')}</h1>
      <p class="body-lg hero-desc text-center max-reading text-muted">{t('aria.desc')}</p>
      <div class="hero-actions">
        <a href="mailto:hello@kat.on" class="btn-primary">{t('aria.cta1')}</a>
        <a href="#capabilities" class="btn-secondary">{t('aria.cta2')}</a>
      </div>
    </Container>
  </Section>

  {/* B. Executive Dashboard */}
  <Section type="content" class="dashboard-section" aria-labelledby="dashboard-heading">
    <Container size="xl">
      <div class="section-header center-container text-center">
        <span class="label text-accent">{t('aria.dash.label')}</span>
        <h2 id="dashboard-heading" class="h2">{t('aria.dash.title')}</h2>
        <p class="body-lg text-muted max-reading section-sub">{t('aria.dash.desc')}</p>
      </div>
      <ARIADashboard />
    </Container>
  </Section>

  {/* C. How ARIA Works — Core Capabilities */}
  <Section type="feature" aria-labelledby="capabilities-heading" id="capabilities">
    <Container size="xl">
      <div class="section-header center-container text-center">
        <span class="label text-accent">{t('aria.cap.label')}</span>
        <h2 id="capabilities-heading" class="h2">{t('aria.cap.title')}</h2>
      </div>
      <div class="grid-2 features-grid">
        {capabilities.map((c) => (
          <Card variant="feature" class="cap-card">
            <span class="cap-icon" aria-hidden="true">{capIcons[c]}</span>
            <h3 class="h4">{t(`aria.cap.${c}.title` as any)}</h3>
            <p class="body text-muted">{t(`aria.cap.${c}.desc` as any)}</p>
          </Card>
        ))}
      </div>
    </Container>
  </Section>

  {/* D. Government Workflow (reuses the Executive Workflow flow, government-framed) */}
  <ExecutiveWorkflow eyebrowKey="aria.gov.eyebrow" titleKey="aria.gov.title" subKey="aria.gov.sub" />

  {/* E. Use Cases */}
  <Section type="content" class="usecase-section" aria-labelledby="usecase-heading">
    <Container size="xl">
      <div class="section-header center-container text-center">
        <span class="label text-accent">{t('aria.uc.label')}</span>
        <h2 id="usecase-heading" class="h2">{t('aria.uc.title')}</h2>
      </div>
      <div class="usecase-grid">
        {useCases.map((n) => (
          <div class="usecase-card">
            <span class="usecase-icon" aria-hidden="true">
              <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" set:html={ucIcons[n]} />
            </span>
            <h3 class="usecase-title">{t(`aria.uc.${n}.title` as any)}</h3>
            <p class="usecase-desc">{t(`aria.uc.${n}.desc` as any)}</p>
          </div>
        ))}
      </div>
    </Container>
  </Section>

  {/* F. Metrics */}
  <Section type="content" class="metrics-section" aria-labelledby="metrics-heading">
    <Container size="lg">
      <div class="section-header center-container text-center">
        <span class="label text-accent">{t('aria.metrics.label')}</span>
        <h2 id="metrics-heading" class="h2">{t('aria.metrics.title')}</h2>
      </div>
      <dl class="metrics-grid">
        {metrics.map((n) => (
          <div class="metric">
            <dt class="metric-value">{t(`aria.metrics.${n}.value` as any)}</dt>
            <dd class="metric-label">{t(`aria.metrics.${n}.label` as any)}</dd>
          </div>
        ))}
      </dl>
    </Container>
  </Section>

  {/* G. Architecture / Security — trust */}
  <Section type="content" aria-labelledby="architecture-heading">
    <Container size="lg">
      <div class="architecture-wrapper">
        <span class="label text-accent">{t('aria.arch.label')}</span>
        <h2 id="architecture-heading" class="h2">{t('aria.arch.title')}</h2>
        <div class="flow-md text-muted body-lg mt-32">
          <p>{t('aria.arch.p')}</p>
          <ul class="architecture-list">
            <li><strong>{t('aria.arch.li1.strong')}</strong> {t('aria.arch.li1.text')}</li>
            <li><strong>{t('aria.arch.li2.strong')}</strong> {t('aria.arch.li2.text')}</li>
            <li><strong>{t('aria.arch.li3.strong')}</strong> {t('aria.arch.li3.text')}</li>
          </ul>
        </div>
      </div>
    </Container>
  </Section>

  {/* H. Premium CTA */}
  <section class="premium-cta" aria-labelledby="cta-heading">
    <div class="premium-cta-glow" aria-hidden="true"></div>
    <div class="container-md premium-cta-inner">
      <span class="premium-cta-badge">
        <span class="badge-dot" aria-hidden="true"></span>
        {t('aria.finalcta.badge')}
      </span>
      <h2 id="cta-heading" class="premium-cta-title">{t('aria.finalcta.title')}</h2>
      <p class="premium-cta-sub">{t('aria.finalcta.sub')}</p>
      <div class="premium-cta-actions">
        <a href="mailto:hello@kat.on" class="premium-btn premium-btn--primary">{t('aria.finalcta.btn')}</a>
        <a href="mailto:hello@kat.on" class="premium-btn premium-btn--ghost">{t('aria.finalcta.secondary')}</a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .center-container { display: flex; flex-direction: column; align-items: center; }
  .text-center { text-align: center; }
  .text-muted { color: var(--color-text-secondary); }
  .text-accent { color: var(--color-accent); }
  .mt-32 { margin-block-start: var(--space-32); }

  .label { display: block; margin-block-end: var(--space-16); }
  .section-header { margin-block-end: var(--space-64); }
  .section-sub { margin-block-start: var(--space-16); }

  /* `.aria-hero-logo` lands on the <img> inside the Logo component. */
  :global(.aria-hero-logo) {
    width: 64px;
    height: 64px;
    margin-block-end: var(--space-24);
    box-shadow: var(--shadow-lg);
  }

  .aria-badges {
    display: flex;
    justify-content: center;
    gap: var(--space-8);
    margin-block-end: var(--space-32);
    flex-wrap: wrap;
  }

  .hero-desc { margin-block-start: var(--space-24); margin-block-end: var(--space-48); }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-16);
  }

  .btn-primary, .btn-secondary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: var(--space-48);
    padding-inline: var(--space-32);
    font-weight: var(--weight-medium);
    border-radius: var(--radius-full);
    text-decoration: none;
    transition: transform var(--motion-fast), box-shadow var(--motion-fast);
  }
  .btn-primary { background-color: var(--color-primary); color: var(--color-surface); box-shadow: var(--shadow-sm); }
  .btn-secondary { background-color: var(--color-surface); color: var(--color-text-primary); border: var(--border-thin); }
  .btn-primary:hover, .btn-secondary:hover { transform: translateY(-2px); box-shadow: var(--shadow-md); }
  .btn-secondary:hover { border-color: var(--color-border-accent); }

  /* ── Executive Dashboard ─────────────────────────── */
  .dashboard-section {
    padding-block-start: var(--space-48);
    background: linear-gradient(180deg, var(--color-background) 0%, var(--color-surface) 100%);
  }

  /* ── How ARIA Works — capability cards ───────────── */
  .cap-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    border-radius: var(--radius-large);
    background: var(--color-accent-light);
    color: var(--color-accent);
    font-size: 1.5rem;
    line-height: 1;
    margin-block-end: var(--space-24);
    transition: transform var(--motion-normal), background var(--motion-fast);
  }
  .cap-card:hover .cap-icon { transform: scale(1.05); background: var(--color-accent-mid); }

  /* ── Use Cases ───────────────────────────────────── */
  .usecase-section { background-color: var(--color-surface); }
  .usecase-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-16);
  }
  @media (min-width: 640px) { .usecase-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1024px) { .usecase-grid { grid-template-columns: repeat(4, 1fr); } }

  .usecase-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-12);
    padding: var(--space-32);
    border-radius: var(--radius-2xl);
    background: var(--color-surface);
    border: var(--border-thin);
    box-shadow: var(--shadow-xs);
    transition: transform var(--motion-normal), box-shadow var(--motion-normal), border-color var(--motion-fast);
  }
  .usecase-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
    border-color: var(--color-border-accent);
  }
  .usecase-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: var(--radius-medium);
    background: var(--color-accent-light);
    color: var(--color-accent);
    margin-block-end: var(--space-8);
  }
  .usecase-icon svg { width: 22px; height: 22px; }
  .usecase-title { font-size: var(--text-card); font-weight: var(--weight-semibold); color: var(--color-primary); margin: 0; }
  .usecase-desc { font-size: var(--text-body-sm); line-height: 1.6; color: var(--color-text-secondary); margin: 0; }

  /* ── Metrics ─────────────────────────────────────── */
  .metrics-section {
    background: linear-gradient(180deg, var(--color-surface) 0%, var(--color-surface-muted) 100%);
  }
  .metrics-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-32);
    margin: 0;
  }
  @media (min-width: 720px) { .metrics-grid { grid-template-columns: repeat(3, 1fr); } }
  .metric {
    text-align: center;
    padding: var(--space-32) var(--space-24);
    border-radius: var(--radius-2xl);
    background: var(--color-surface);
    border: var(--border-thin);
    box-shadow: var(--shadow-sm);
  }
  .metric-value {
    font-size: clamp(2.5rem, 1.8rem + 3vw, 3.5rem);
    font-weight: var(--weight-bold);
    line-height: 1;
    letter-spacing: -0.03em;
    color: var(--color-accent);
  }
  .metric-label {
    margin: var(--space-12) 0 0;
    font-size: var(--text-body-sm);
    color: var(--color-text-secondary);
    line-height: 1.5;
  }

  /* ── Architecture ────────────────────────────────── */
  .architecture-wrapper {
    background-color: var(--color-surface);
    border: var(--border-thin);
    border-radius: var(--radius-2xl);
    padding: var(--space-64);
  }
  .architecture-list {
    margin-block-start: var(--space-24);
    padding-inline-start: var(--space-24);
    display: flex;
    flex-direction: column;
    gap: var(--space-12);
  }

  /* ── Premium CTA ─────────────────────────────────── */
  .premium-cta {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    padding-block: var(--space-128);
    text-align: center;
    background:
      radial-gradient(120% 80% at 50% 0%, rgba(59,130,246,0.18) 0%, transparent 60%),
      linear-gradient(160deg, #0B1120 0%, #111827 55%, #0F172A 100%);
    color: #F8FAFC;
  }
  .premium-cta-glow {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(255,255,255,0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.03) 1px, transparent 1px);
    background-size: 46px 46px;
    mask-image: radial-gradient(120% 100% at 50% 0%, #000 0%, transparent 70%);
    z-index: -1;
  }
  .premium-cta-inner { display: flex; flex-direction: column; align-items: center; }
  .premium-cta-badge {
    display: inline-flex;
    align-items: center;
    gap: var(--space-8);
    padding: var(--space-8) var(--space-16);
    border-radius: var(--radius-full);
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.12);
    font-size: var(--text-label);
    font-weight: var(--weight-semibold);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #BFDBFE;
  }
  .badge-dot {
    width: 6px; height: 6px; border-radius: 50%;
    background: #3B82F6; box-shadow: 0 0 0 4px rgba(59,130,246,0.2);
  }
  .premium-cta-title {
    margin-block: var(--space-24) var(--space-16);
    color: #FFFFFF;
    font-size: var(--text-display);
    line-height: 1.06;
    font-weight: var(--weight-bold);
    letter-spacing: -0.04em;
  }
  .premium-cta-sub {
    color: #94A3B8;
    font-size: 1.0625rem;
    line-height: 1.6;
    max-width: 48ch;
    margin-block-end: var(--space-48);
  }
  .premium-cta-actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-16);
  }
  .premium-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: var(--space-48);
    padding-inline: var(--space-32);
    border-radius: var(--radius-full);
    font-weight: var(--weight-semibold);
    font-size: var(--text-body-sm);
    text-decoration: none;
    transition: transform var(--motion-fast), box-shadow var(--motion-fast), background var(--motion-fast);
  }
  .premium-btn--primary { background: #FFFFFF; color: #0F172A; }
  .premium-btn--primary:hover { transform: translateY(-2px); box-shadow: 0 12px 32px rgba(0,0,0,0.4); }
  .premium-btn--ghost { background: rgba(255,255,255,0.06); color: #F8FAFC; border: 1px solid rgba(255,255,255,0.16); }
  .premium-btn--ghost:hover { background: rgba(255,255,255,0.12); transform: translateY(-2px); }
</style>
