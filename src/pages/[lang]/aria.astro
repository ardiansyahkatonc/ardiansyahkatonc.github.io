---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { Section } from '../../components/ui/section';
import { Container } from '../../components/ui/container';
import { Card } from '../../components/ui/card';
import { Badge } from '../../components/ui/badge';
import ARIADashboard from '../../components/ui/mockup/ARIADashboard.astro';
import Logo from '../../components/common/Logo.astro';
import { getLangFromUrl, useTranslations } from '../../i18n';

export function getStaticPaths() {
  return [{ params: { lang: 'id' } }, { params: { lang: 'en' } }];
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const capabilities = ['meeting', 'document', 'knowledge', 'workspace'] as const;
const capIcons: Record<string, string> = {
  meeting: '◎',
  document: '◈',
  knowledge: '▣',
  workspace: '⬡',
};
---

<BaseLayout title={t('meta.aria.title')} description={t('meta.aria.desc')}>

  {/* A. Hero */}
  <Section type="hero" aria-labelledby="aria-hero-heading" class="aria-hero">
    <Container size="lg" class="center-container">
      <Logo brand="aria" size="lg" class="aria-hero-logo" alt="ARIA" />
      <div class="aria-badges">
        <Badge variant="primary">{t('aria.badge1')}</Badge>
        <Badge variant="neutral">{t('aria.badge2')}</Badge>
      </div>
      <h1 id="aria-hero-heading" class="display-xl text-center">{t('aria.h1')}</h1>
      <p class="body-lg hero-desc text-center max-reading text-muted">{t('aria.desc')}</p>
      <div class="hero-actions">
        <a href="mailto:hello@kat.on" class="btn-primary">{t('aria.cta1')}</a>
        <a href="#capabilities" class="btn-secondary">{t('aria.cta2')}</a>
      </div>
    </Container>
  </Section>

  {/* B. Product Preview */}
  <Section type="content" class="mockup-section">
    <Container size="xl">
      <ARIADashboard />
    </Container>
  </Section>

  {/* C. Problem & Solution */}
  <Section type="content" aria-labelledby="paradigm-heading">
    <Container size="xl">
      <div class="grid-2 paradigm-grid">
        <div class="paradigm-block problem">
          <span class="label text-muted">{t('aria.problem.label')}</span>
          <h2 class="h3">{t('aria.problem.title')}</h2>
          <p class="body text-muted">{t('aria.problem.desc')}</p>
        </div>
        <div class="paradigm-block solution">
          <span class="label text-accent">{t('aria.solution.label')}</span>
          <h2 class="h3">{t('aria.solution.title')}</h2>
          <p class="body text-muted">{t('aria.solution.desc')}</p>
        </div>
      </div>
    </Container>
  </Section>

  {/* D. Core Capabilities */}
  <Section type="feature" aria-labelledby="capabilities-heading" id="capabilities">
    <Container size="xl">
      <div class="section-header center-container text-center">
        <span class="label text-muted">{t('aria.cap.label')}</span>
        <h2 id="capabilities-heading" class="h2">{t('aria.cap.title')}</h2>
      </div>
      <div class="grid-2 features-grid">
        {capabilities.map((c) => (
          <Card variant="feature">
            <div class="feature-icon">{capIcons[c]}</div>
            <h3 class="h4">{t(`aria.cap.${c}.title` as any)}</h3>
            <p class="body text-muted">{t(`aria.cap.${c}.desc` as any)}</p>
          </Card>
        ))}
      </div>
    </Container>
  </Section>

  {/* E. Product Architecture */}
  <Section type="content" aria-labelledby="architecture-heading">
    <Container size="lg">
      <div class="architecture-wrapper">
        <span class="label text-muted">{t('aria.arch.label')}</span>
        <h2 id="architecture-heading" class="h2">{t('aria.arch.title')}</h2>
        <div class="flow-md text-muted body-lg mt-32">
          <p>{t('aria.arch.p')}</p>
          <ul class="architecture-list">
            <li><strong>{t('aria.arch.li1.strong')}</strong> {t('aria.arch.li1.text')}</li>
            <li><strong>{t('aria.arch.li2.strong')}</strong> {t('aria.arch.li2.text')}</li>
            <li><strong>{t('aria.arch.li3.strong')}</strong> {t('aria.arch.li3.text')}</li>
          </ul>
        </div>
      </div>
    </Container>
  </Section>

  {/* F. Roadmap */}
  <Section type="content" aria-labelledby="roadmap-heading">
    <Container size="xl">
      <div class="section-header">
        <span class="label text-muted">{t('aria.road.label')}</span>
        <h2 id="roadmap-heading" class="h2">{t('aria.road.title')}</h2>
      </div>
      <div class="grid-2 roadmap-grid">
        <Card variant="default">
          <Badge variant="neutral">Phase 4</Badge>
          <h3 class="h4 mt-16">{t('aria.road.p4.title')}</h3>
          <ul class="roadmap-list body text-muted mt-16">
            <li>{t('aria.road.p4.li1')}</li>
            <li>{t('aria.road.p4.li2')}</li>
            <li>{t('aria.road.p4.li3')}</li>
          </ul>
        </Card>
        <Card variant="default">
          <Badge variant="neutral">Phase 5</Badge>
          <h3 class="h4 mt-16">{t('aria.road.p5.title')}</h3>
          <ul class="roadmap-list body text-muted mt-16">
            <li>{t('aria.road.p5.li1')}</li>
            <li>{t('aria.road.p5.li2')}</li>
            <li>{t('aria.road.p5.li3')}</li>
          </ul>
        </Card>
      </div>
    </Container>
  </Section>

  {/* G. CTA */}
  <Section type="cta" class="aria-cta">
    <Container size="md" class="center-container text-center">
      <h2 class="display text-surface">{t('aria.finalcta.title')}</h2>
      <p class="body-lg text-surface-muted mt-24 max-reading">{t('aria.finalcta.sub')}</p>
      <div class="hero-actions mt-48">
        <a href="mailto:hello@kat.on" class="btn-primary-inverted">{t('aria.finalcta.btn')}</a>
      </div>
    </Container>
  </Section>

</BaseLayout>

<style>
  .center-container {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .text-center { text-align: center; }
  .text-muted { color: var(--color-text-secondary); }
  .text-accent { color: var(--color-accent); }
  .text-surface { color: var(--color-surface); }
  .text-surface-muted { color: rgba(255,255,255,0.7); }

  .mt-16 { margin-block-start: var(--space-16); }
  .mt-24 { margin-block-start: var(--space-24); }
  .mt-32 { margin-block-start: var(--space-32); }
  .mt-48 { margin-block-start: var(--space-48); }

  .label {
    display: block;
    margin-block-end: var(--space-16);
  }

  /* `.aria-hero-logo` lands on the <img> inside the Logo component, so it must
     be targeted globally (Astro scopes component-local classes only). */
  :global(.aria-hero-logo) {
    width: 64px;
    height: 64px;
    margin-block-end: var(--space-24);
    box-shadow: var(--shadow-lg);
  }

  .aria-badges {
    display: flex;
    justify-content: center;
    gap: var(--space-8);
    margin-block-end: var(--space-32);
    flex-wrap: wrap;
  }

  .hero-desc {
    margin-block-start: var(--space-24);
    margin-block-end: var(--space-48);
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-16);
  }

  .btn-primary, .btn-secondary, .btn-primary-inverted {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: var(--space-48);
    padding-inline: var(--space-32);
    font-weight: var(--weight-medium);
    border-radius: var(--radius-full);
    text-decoration: none;
    transition: transform var(--motion-fast), box-shadow var(--motion-fast);
  }

  .btn-primary {
    background-color: var(--color-primary);
    color: var(--color-surface);
    box-shadow: var(--shadow-sm);
  }

  .btn-secondary {
    background-color: var(--color-surface);
    color: var(--color-text-primary);
    border: var(--border-light);
  }

  .btn-primary-inverted {
    background-color: var(--color-surface);
    color: var(--color-primary);
  }

  .btn-primary:hover, .btn-secondary:hover, .btn-primary-inverted:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
  }

  .btn-secondary:hover {
    border-color: var(--color-border);
  }

  .mockup-section {
    padding-block-start: 0; /* Tighten space under hero */
  }

  .paradigm-grid {
    gap: var(--space-48);
  }

  .paradigm-block {
    padding: var(--space-48);
    border-radius: var(--radius-2xl);
  }

  .paradigm-block.problem {
    background-color: var(--color-surface);
    border: var(--border-light);
  }

  .paradigm-block.solution {
    background-color: var(--color-surface-muted);
    border: 1px solid var(--color-border);
  }

  .section-header {
    margin-block-end: var(--space-64);
  }

  .feature-icon {
    font-size: var(--text-display);
    color: var(--color-text-secondary);
    margin-block-end: var(--space-24);
    line-height: 1;
  }

  .architecture-wrapper {
    background-color: var(--color-surface);
    border: var(--border-light);
    border-radius: var(--radius-2xl);
    padding: var(--space-64);
  }

  .architecture-list {
    margin-block-start: var(--space-24);
    padding-inline-start: var(--space-24);
    display: flex;
    flex-direction: column;
    gap: var(--space-12);
  }

  .roadmap-list {
    padding-inline-start: var(--space-24);
    display: flex;
    flex-direction: column;
    gap: var(--space-12);
  }

  .aria-cta {
    background-color: var(--color-primary);
    border-top: none;
  }
</style>
