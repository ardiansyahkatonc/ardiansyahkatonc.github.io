---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { Section } from '../../components/ui/section';
import { Container } from '../../components/ui/container';
import { Card } from '../../components/ui/card';
import { social } from '../../config/social';
import { BRAND } from '../../config/brand';
import { getLangFromUrl, useTranslations } from '../../i18n';

export function getStaticPaths() {
  return [{ params: { lang: 'id' } }, { params: { lang: 'en' } }];
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<BaseLayout title={t('meta.contact.title')} description={t('meta.contact.desc')}>
  <Section type="hero">
    <Container size="md">
      <span class="label text-muted">{t('contact.label')}</span>
      <h1 class="display">{t('contact.h1')}</h1>
      <p class="body-lg text-muted">{t('contact.desc')}</p>
    </Container>
  </Section>

  <Section type="content">
    <Container size="lg">
      <div class="grid-2">
        <div class="contact-info flow-xl">
          <div>
            <h2 class="h3">{t('contact.gov.title')}</h2>
            <p class="body text-muted">{t('contact.gov.desc')}</p>
          </div>
          <div>
            <h2 class="h3">{t('contact.avail.title')}</h2>
            <p class="body text-muted">{t('contact.avail.desc')}</p>
          </div>
        </div>

        <div class="contact-methods">
          <Card variant="feature" class="contact-card">
            <h3 class="h4">{t('contact.direct.title')}</h3>
            <ul class="contact-list body-lg">
              <li>
                <span class="text-muted">{t('contact.whatsapp')}</span>
                <a href={social.whatsapp} class="contact-link" target="_blank" rel="noopener noreferrer">{BRAND.contact.whatsappDisplay}</a>
              </li>
              <li>
                <span class="text-muted">{t('contact.email')}</span>
                <a href={social.email} class="contact-link">hello@kat.on</a>
              </li>
              <li>
                <span class="text-muted">{t('contact.github')}</span>
                <a href={social.github} class="contact-link" target="_blank" rel="noopener noreferrer">github.com/ardiansyahkatonc</a>
              </li>
              <li>
                <span class="text-muted">{t('contact.linkedin')}</span>
                <a href={social.linkedin} class="contact-link" target="_blank" rel="noopener noreferrer">linkedin.com/in/ardiansyah-katon-cahyadi</a>
              </li>
              <li>
                <span class="text-muted">{t('contact.instagram')}</span>
                <a href={social.instagram} class="contact-link" target="_blank" rel="noopener noreferrer">@ardiansyahkatonc</a>
              </li>
            </ul>
            <div class="cta-wrapper">
              <a href={social.whatsapp} class="btn-primary" target="_blank" rel="noopener noreferrer">{t('contact.cta')}</a>
            </div>
          </Card>
        </div>
      </div>
    </Container>
  </Section>
</BaseLayout>

<style>
  .text-muted {
    color: var(--color-text-secondary);
  }

  .label {
    display: block;
    margin-block-end: var(--space-24);
  }

  .contact-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-32);
  }

  .contact-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-24);
  }

  .contact-list li {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .contact-link {
    color: var(--color-text-primary);
    text-decoration: none;
    font-weight: var(--weight-medium);
    transition: color var(--motion-fast);
  }

  .contact-link:hover {
    color: var(--color-accent);
    text-decoration: underline;
  }

  .cta-wrapper {
    margin-block-start: var(--space-16);
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: var(--space-48);
    padding-inline: var(--space-32);
    background-color: var(--color-primary);
    color: var(--color-surface);
    border-radius: var(--radius-full);
    text-decoration: none;
    font-weight: var(--weight-medium);
    transition: transform var(--motion-fast);
    width: 100%;
  }

  .btn-primary:hover {
    transform: translateY(-2px);
  }
</style>
