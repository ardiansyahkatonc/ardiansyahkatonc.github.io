---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { Section } from '../../components/ui/section';
import { Container } from '../../components/ui/container';
import { Card } from '../../components/ui/card';
import { getLangFromUrl, useTranslations } from '../../i18n';

export function getStaticPaths() {
  return [{ params: { lang: 'id' } }, { params: { lang: 'en' } }];
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

// Same six milestones as the homepage Story timeline (single source of copy).
const timeline = ['m1', 'm2', 'm3', 'm4', 'm5', 'm6'] as const;
---

<BaseLayout title={t('meta.about.title')} description={t('meta.about.desc')}>
  <Section type="hero" class="about-hero">
    <Container size="md">
      <span class="label text-muted">{t('about.label')}</span>
      <h1 class="display">{t('about.h1')}</h1>
      <p class="body-lg text-muted">{t('about.desc')}</p>
    </Container>
  </Section>

  <Section type="content">
    <Container size="lg">
      <div class="grid-2">
        <Card variant="feature">
          <h2 class="h3">{t('about.mission.title')}</h2>
          <p class="body text-muted">{t('about.mission.desc')}</p>
        </Card>
        <Card variant="feature">
          <h2 class="h3">{t('about.vision.title')}</h2>
          <p class="body text-muted">{t('about.vision.desc')}</p>
        </Card>
      </div>
    </Container>
  </Section>

  <Section type="content">
    <Container size="md">
      <span class="label text-muted">{t('about.philosophy.label')}</span>
      <h2 class="h2">{t('about.philosophy.title')}</h2>
      <div class="flow-md text-muted body-lg">
        <p>{t('about.philosophy.p1')}</p>
        <p>{t('about.philosophy.p2')}</p>
        <p>{t('about.philosophy.p3')}</p>
      </div>
    </Container>
  </Section>

  <Section type="content">
    <Container size="md">
      <span class="label text-muted">{t('about.timeline.label')}</span>
      <h2 class="h2">{t('about.timeline.title')}</h2>
      <div class="timeline flow-xl">
        <div class="timeline-group">
          <h3 class="h4">2026</h3>
          <div class="timeline-items flow-md">
            {timeline.map((m) => (
              <div class="timeline-item">
                <span class="label text-muted timeline-year">{t(`journey.${m}.year` as any)}</span>
                <h4 class="title">{t(`journey.${m}.title` as any)}</h4>
                <p class="body text-muted">{t(`journey.${m}.desc` as any)}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </Container>
  </Section>
</BaseLayout>

<style>
  .about-hero {
    border-bottom: var(--border-light);
  }

  .text-muted {
    color: var(--color-text-secondary);
  }

  .label {
    display: block;
    margin-block-end: var(--space-24);
  }

  .timeline-group {
    border-left: var(--border-light);
    padding-left: var(--space-32);
    margin-left: var(--space-8);
  }
</style>
