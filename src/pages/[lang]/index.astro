---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/sections/Hero.astro';
import Problem from '../../components/sections/Problem.astro';
import AriaSpotlight from '../../components/sections/AriaSpotlight.astro';
import ExecutiveWorkflow from '../../components/sections/ExecutiveWorkflow.astro';
import Features from '../../components/sections/Features.astro';
import EcosystemPreview from '../../components/sections/EcosystemPreview.astro';
import EngineeringTrust from '../../components/sections/EngineeringTrust.astro';
import Journey from '../../components/sections/Journey.astro';
import CTA from '../../components/sections/CTA.astro';
import { getLangFromUrl, useTranslations } from '../../i18n';

export function getStaticPaths() {
  return [{ params: { lang: 'id' } }, { params: { lang: 'en' } }];
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<BaseLayout title={t('meta.home.title')} description={t('meta.home.desc')}>
  <Hero />
  <Problem />
  <AriaSpotlight />
  <ExecutiveWorkflow />
  <Features />
  <EcosystemPreview />
  <EngineeringTrust />
  <Journey />
  <CTA />
</BaseLayout>
