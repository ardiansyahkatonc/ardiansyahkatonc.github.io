---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { Section } from '../../components/ui/section';
import { Container } from '../../components/ui/container';
import { Card } from '../../components/ui/card';
import { Badge } from '../../components/ui/badge';
import { products } from '../../config/products';
import { getLangFromUrl, useTranslations, localizePath } from '../../i18n';

export function getStaticPaths() {
  return [{ params: { lang: 'id' } }, { params: { lang: 'en' } }];
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<BaseLayout title={t('meta.projects.title')} description={t('meta.projects.desc')}>
  <Section type="hero">
    <Container size="md">
      <span class="label text-muted">{t('projects.label')}</span>
      <h1 class="display">{t('projects.h1')}</h1>
      <p class="body-lg text-muted">{t('projects.desc')}</p>
    </Container>
  </Section>

  <Section type="content">
    <Container size="lg">
      <div class="grid-1 flow-xl">
        {products.map((product) => (
          <Card variant="default" class="product-card">
            <div class="product-header">
              <div class="product-title-group">
                <h2 class="h2 product-title">{product.title}</h2>
                <Badge variant={product.status === 'Available' ? 'primary' : 'neutral'}>{product.status}</Badge>
              </div>
              <p class="body-lg text-muted product-desc">{t(`projects.${product.id}.desc` as any)}</p>
            </div>

            <div class="product-details grid-2">
              <div class="detail-block">
                <h3 class="label text-muted">{t('projects.tech')}</h3>
                <p class="body">{product.technology || t('projects.techDefault')}</p>
              </div>
              <div class="detail-block">
                <h3 class="label text-muted">{t('projects.impact')}</h3>
                <p class="body">{product.impact || t('projects.impactDefault')}</p>
              </div>
            </div>

            {product.id === 'aria' && (
              <div class="product-actions">
                <a href={localizePath('/aria', lang)} class="btn-primary">{t('projects.viewDetails')}</a>
              </div>
            )}
          </Card>
        ))}
      </div>
    </Container>
  </Section>
</BaseLayout>

<style>
  .text-muted {
    color: var(--color-text-secondary);
  }

  .label {
    display: block;
    margin-block-end: var(--space-16);
  }

  .product-card {
    padding: var(--space-48);
    display: flex;
    flex-direction: column;
    gap: var(--space-48);
  }

  .product-title-group {
    display: flex;
    align-items: center;
    gap: var(--space-16);
    flex-wrap: wrap;
    margin-block-end: var(--space-16);
  }

  .product-title {
    margin: 0;
  }

  .product-desc {
    max-width: 60ch;
  }

  .product-details {
    padding-top: var(--space-32);
    border-top: var(--border-light);
  }

  .detail-block .label {
    margin-block-end: var(--space-8);
  }

  .detail-block .body {
    margin: 0;
    color: var(--color-text-primary);
  }

  .product-actions {
    padding-top: var(--space-32);
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: var(--space-48);
    padding-inline: var(--space-32);
    background-color: var(--color-primary);
    color: var(--color-surface);
    border-radius: var(--radius-full);
    text-decoration: none;
    font-weight: var(--weight-medium);
    transition: transform var(--motion-fast);
  }

  .btn-primary:hover {
    transform: translateY(-2px);
  }
</style>
