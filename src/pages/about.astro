---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Section } from '../components/ui/section';
import { Container } from '../components/ui/container';
import { Card } from '../components/ui/card';
import { journey } from '../config/journey';
---

<BaseLayout 
  title="About kat.on | AI-Native Product Studio"
  description="kat.on is an AI-Native Product Studio dedicated to simplifying public sector workflows through human-centered artificial intelligence."
>
  <Section type="hero" class="about-hero">
    <Container size="md">
      <span class="label text-muted">Company</span>
      <h1 class="display">Why kat.on exists.</h1>
      <p class="body-lg text-muted">
        Technology should simplify work, not make it more complicated. We build AI-native products that help organizations manage knowledge, streamline workflows, and accelerate public service delivery.
      </p>
    </Container>
  </Section>

  <Section type="content">
    <Container size="lg">
      <div class="grid-2">
        <Card variant="feature">
          <h2 class="h3">Mission</h2>
          <p class="body text-muted">To reduce repetitive administrative work through practical, transparent, and highly adoptable AI solutions.</p>
        </Card>
        <Card variant="feature">
          <h2 class="h3">Vision</h2>
          <p class="body text-muted">To become the trusted AI partner for the Indonesian public sector, transforming government workflows into efficient, knowledge-driven operations.</p>
        </Card>
      </div>
    </Container>
  </Section>

  <Section type="content">
    <Container size="md">
      <span class="label text-muted">Philosophy</span>
      <h2 class="h2">The AI-Native Approach</h2>
      <div class="flow-md text-muted body-lg">
        <p>We do not treat AI as a decorative feature or an afterthought. At kat.on, AI is the foundational layer of our product architecture.</p>
        <p>Our philosophy, governed by the KATON COMMAND CENTER, mandates that the best solution is the one that reduces future complexity. We prioritize maintainability, simplicity, scalability, and relentless documentation.</p>
        <p>We believe in Human-First AI: technology that assists rather than replaces, providing explainable and secure augmentation for knowledge workers.</p>
      </div>
    </Container>
  </Section>

  <Section type="content">
    <Container size="md">
      <span class="label text-muted">Timeline</span>
      <h2 class="h2">Our Journey</h2>
      <div class="timeline flow-xl">
        {journey.map(group => (
          <div class="timeline-group">
            <h3 class="h4">{group.year}</h3>
            <div class="timeline-items flow-md">
              {group.milestones.map(milestone => (
                <div class="timeline-item">
                  <h4 class="title">{milestone.title}</h4>
                  <p class="body text-muted">{milestone.description}</p>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
    </Container>
  </Section>
</BaseLayout>

<style>
  .about-hero {
    border-bottom: var(--border-light);
  }

  .text-muted {
    color: var(--color-text-secondary);
  }

  .label {
    display: block;
    margin-block-end: var(--space-24);
  }

  .timeline-group {
    border-left: var(--border-light);
    padding-left: var(--space-32);
    margin-left: var(--space-8);
  }
</style>
