---
// =============================================================================
// Language gateway ( / )
// -----------------------------------------------------------------------------
// Detects the visitor's saved preference or browser language and redirects to
// the localized home (/id or /en). Static-site friendly: inline script does the
// redirect, with a <meta refresh> + <noscript> fallback (default: /id).
// Detection rule: saved preference wins → browser 'en*' → /en → otherwise /id.
// =============================================================================
import { SEO } from '../config/seo';
const idHome = new URL('/id/', SEO.siteUrl).toString();
---
<!DOCTYPE html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>kat.on</title>
    <meta name="robots" content="noindex, follow" />
    <link rel="canonical" href={idHome} />
    <script is:inline>
      (function () {
        try {
          var stored = localStorage.getItem('katon-lang');
          var lang =
            stored === 'id' || stored === 'en'
              ? stored
              : (navigator.language || 'id').toLowerCase().indexOf('en') === 0
                ? 'en'
                : 'id';
          window.location.replace('/' + lang + '/');
        } catch (e) {
          window.location.replace('/id/');
        }
      })();
    </script>
    <meta http-equiv="refresh" content="0; url=/id/" />
  </head>
  <body>
    <noscript>
      <p>Continue to <a href="/id/">Bahasa Indonesia</a> · <a href="/en/">English</a>.</p>
    </noscript>
  </body>
</html>
