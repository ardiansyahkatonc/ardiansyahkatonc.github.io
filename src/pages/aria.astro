---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Section } from '../components/ui/section';
import { Container } from '../components/ui/container';
import { Card } from '../components/ui/card';
import { Badge } from '../components/ui/badge';
import ARIAMockup from '../components/ui/mockup/ARIAMockup.astro';
---

<BaseLayout 
  title="ARIA | AI Executive Assistant for the Public Sector"
  description="Transform meetings, documents, and organizational knowledge into structured, actionable information with ARIA's AI-assisted workflows."
>
  
  {/* A. Hero */}
  <Section type="hero" aria-labelledby="aria-hero-heading" class="aria-hero">
    <Container size="lg" class="center-container">
      <div class="aria-badges">
        <Badge variant="primary">ARIA Flagship</Badge>
        <Badge variant="neutral">Enterprise Ready</Badge>
      </div>
      <h1 id="aria-hero-heading" class="display-xl text-center">AI Executive Assistant</h1>
      <p class="body-lg hero-desc text-center max-reading text-muted">
        ARIA listens, structures, and organizes information securely—allowing government teams to focus on public service rather than paperwork.
      </p>
      <div class="hero-actions">
        <a href="mailto:hello@kat.on" class="btn-primary">Request Demo</a>
        <a href="#capabilities" class="btn-secondary">Explore Capabilities</a>
      </div>
    </Container>
  </Section>

  {/* B. Product Preview */}
  <Section type="content" class="mockup-section">
    <Container size="xl">
      <ARIAMockup />
    </Container>
  </Section>

  {/* C. Problem & Solution */}
  <Section type="content" aria-labelledby="paradigm-heading">
    <Container size="xl">
      <div class="grid-2 paradigm-grid">
        <div class="paradigm-block problem">
          <span class="label text-muted">The Problem</span>
          <h2 class="h3">Friction and Fragmentation</h2>
          <p class="body text-muted">Critical information remains scattered across emails, disjointed documents, and unrecorded meetings. This results in repetitive administrative work and siloed institutional knowledge.</p>
        </div>
        <div class="paradigm-block solution">
          <span class="label text-accent">The Solution</span>
          <h2 class="h3">Structured Intelligence</h2>
          <p class="body text-muted">By integrating directly into your daily operations, ARIA acts as an intelligent assistant that structures data at the source, creating a unified, searchable, and actionable organizational memory.</p>
        </div>
      </div>
    </Container>
  </Section>

  {/* D. Core Capabilities */}
  <Section type="feature" aria-labelledby="capabilities-heading" id="capabilities">
    <Container size="xl">
      <div class="section-header center-container text-center">
        <span class="label text-muted">Capabilities</span>
        <h2 id="capabilities-heading" class="h2">How ARIA Works</h2>
      </div>
      <div class="grid-2 features-grid">
        <Card variant="feature">
          <div class="feature-icon">◎</div>
          <h3 class="h4">Meeting Intelligence</h3>
          <p class="body text-muted">Automatically organize meetings into structured notes, decisions, and tracked action items without manual intervention.</p>
        </Card>
        <Card variant="feature">
          <div class="feature-icon">◈</div>
          <h3 class="h4">Document Automation</h3>
          <p class="body text-muted">Accelerate administrative document creation using AI-assisted workflows powered by your organization's context.</p>
        </Card>
        <Card variant="feature">
          <div class="feature-icon">▣</div>
          <h3 class="h4">Knowledge Management</h3>
          <p class="body text-muted">Build a dynamic institutional knowledge base that remains searchable, contextual, and reusable across departments.</p>
        </Card>
        <Card variant="feature">
          <div class="feature-icon">⬡</div>
          <h3 class="h4">AI Workspace</h3>
          <p class="body text-muted">A centralized, secure interface for all AI-assisted tasks, ensuring consistent output and strict data privacy compliance.</p>
        </Card>
      </div>
    </Container>
  </Section>

  {/* E. Product Architecture */}
  <Section type="content" aria-labelledby="architecture-heading">
    <Container size="lg">
      <div class="architecture-wrapper">
        <span class="label text-muted">Architecture</span>
        <h2 id="architecture-heading" class="h2">Enterprise Grade Security</h2>
        <div class="flow-md text-muted body-lg mt-32">
          <p>ARIA is built on an isolated data architecture designed specifically for the public sector. Your organizational data never trains public models.</p>
          <ul class="architecture-list">
            <li><strong>Data Isolation:</strong> Dedicated tenant environments.</li>
            <li><strong>Audit Logging:</strong> Comprehensive tracking of all AI interactions.</li>
            <li><strong>Explainable AI:</strong> Tracing generated outputs back to source documents.</li>
          </ul>
        </div>
      </div>
    </Container>
  </Section>

  {/* F. Roadmap */}
  <Section type="content" aria-labelledby="roadmap-heading">
    <Container size="xl">
      <div class="section-header">
        <span class="label text-muted">Roadmap</span>
        <h2 id="roadmap-heading" class="h2">Future Evolution</h2>
      </div>
      <div class="grid-2 roadmap-grid">
        <Card variant="default">
          <Badge variant="neutral">Phase 4</Badge>
          <h3 class="h4 mt-16">Ecosystem Expansion</h3>
          <ul class="roadmap-list body text-muted mt-16">
            <li>Knowledge Graph Integration</li>
            <li>Advanced Automation Engine</li>
            <li>Organization Memory Sync</li>
          </ul>
        </Card>
        <Card variant="default">
          <Badge variant="neutral">Phase 5</Badge>
          <h3 class="h4 mt-16">Platform Scale</h3>
          <ul class="roadmap-list body text-muted mt-16">
            <li>Multi-Organization Support</li>
            <li>Public API & Integrations</li>
            <li>Enterprise Agent Platform</li>
          </ul>
        </Card>
      </div>
    </Container>
  </Section>

  {/* G. CTA */}
  <Section type="cta" class="aria-cta">
    <Container size="md" class="center-container text-center">
      <h2 class="display text-surface">Ready to modernize?</h2>
      <p class="body-lg text-surface-muted mt-24 max-reading">Discover how ARIA can transform your agency's administrative workflows.</p>
      <div class="hero-actions mt-48">
        <a href="mailto:hello@kat.on" class="btn-primary-inverted">Schedule a Demo</a>
      </div>
    </Container>
  </Section>

</BaseLayout>

<style>
  .center-container {
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  
  .text-center { text-align: center; }
  .text-muted { color: var(--color-text-secondary); }
  .text-accent { color: var(--color-accent); }
  .text-surface { color: var(--color-surface); }
  .text-surface-muted { color: rgba(255,255,255,0.7); }
  
  .mt-16 { margin-block-start: var(--space-16); }
  .mt-24 { margin-block-start: var(--space-24); }
  .mt-32 { margin-block-start: var(--space-32); }
  .mt-48 { margin-block-start: var(--space-48); }

  .label {
    display: block;
    margin-block-end: var(--space-16);
  }

  .aria-badges {
    display: flex;
    justify-content: center;
    gap: var(--space-8);
    margin-block-end: var(--space-32);
    flex-wrap: wrap;
  }

  .hero-desc {
    margin-block-start: var(--space-24);
    margin-block-end: var(--space-48);
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-16);
  }

  .btn-primary, .btn-secondary, .btn-primary-inverted {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: var(--space-48);
    padding-inline: var(--space-32);
    font-weight: var(--weight-medium);
    border-radius: var(--radius-full);
    text-decoration: none;
    transition: transform var(--motion-fast), box-shadow var(--motion-fast);
  }

  .btn-primary {
    background-color: var(--color-primary);
    color: var(--color-surface);
    box-shadow: var(--shadow-sm);
  }

  .btn-secondary {
    background-color: var(--color-surface);
    color: var(--color-text-primary);
    border: var(--border-light);
  }

  .btn-primary-inverted {
    background-color: var(--color-surface);
    color: var(--color-primary);
  }

  .btn-primary:hover, .btn-secondary:hover, .btn-primary-inverted:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
  }
  
  .btn-secondary:hover {
    border-color: var(--color-border);
  }

  .mockup-section {
    padding-block-start: 0; /* Tighten space under hero */
  }

  .paradigm-grid {
    gap: var(--space-48);
  }

  .paradigm-block {
    padding: var(--space-48);
    border-radius: var(--radius-2xl);
  }
  
  .paradigm-block.problem {
    background-color: var(--color-surface);
    border: var(--border-light);
  }
  
  .paradigm-block.solution {
    background-color: var(--color-surface-muted);
    border: 1px solid var(--color-border);
  }

  .section-header {
    margin-block-end: var(--space-64);
  }

  .feature-icon {
    font-size: var(--text-display);
    color: var(--color-text-secondary);
    margin-block-end: var(--space-24);
    line-height: 1;
  }

  .architecture-wrapper {
    background-color: var(--color-surface);
    border: var(--border-light);
    border-radius: var(--radius-2xl);
    padding: var(--space-64);
  }

  .architecture-list {
    margin-block-start: var(--space-24);
    padding-inline-start: var(--space-24);
    display: flex;
    flex-direction: column;
    gap: var(--space-12);
  }

  .roadmap-list {
    padding-inline-start: var(--space-24);
    display: flex;
    flex-direction: column;
    gap: var(--space-12);
  }

  .aria-cta {
    background-color: var(--color-primary);
    border-top: none;
  }
</style>
