---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Section } from '../components/ui/section';
import { Container } from '../components/ui/container';
import { Card } from '../components/ui/card';
import { Badge } from '../components/ui/badge';
---

<BaseLayout 
  title="ARIA | AI Executive Assistant for the Public Sector"
  description="Transform meetings, documents, and organizational knowledge into structured, actionable information with ARIA's AI-assisted workflows."
>
  
  {/* A. ARIA Hero / Highlight Section */}
  <Section type="hero" aria-labelledby="aria-hero-heading" class="aria-hero">
    <Container size="xl" class="center-container">
      <div class="aria-badges">
        <Badge variant="primary">Launching July 2026</Badge>
        <Badge variant="neutral">Built with AI-Native Engineering</Badge>
      </div>
      <h1 id="aria-hero-heading" class="display-xl text-center">ARIA</h1>
      <p class="subtitle text-center">AI Executive Assistant</p>
      <p class="body-lg hero-desc text-center max-reading">The flagship AI solution for government workflows.</p>
    </Container>
  </Section>

  {/* B. The Product Story */}
  <Section type="content" aria-labelledby="story-heading" class="story-section">
    <Container size="xl">
      <div class="story-grid">
        <div class="story-block">
          <span class="label">Problem</span>
          <h2 class="h3">Current Reality</h2>
          <p class="body text-muted">Government agencies manage complex operations, but critical information often remains scattered across emails, disjointed documents, and unrecorded meetings. This results in repetitive administrative work and siloed institutional knowledge.</p>
        </div>
        <div class="story-block">
          <span class="label">ARIA Solution</span>
          <h2 class="h3">AI-Assisted Workflows</h2>
          <p class="body text-muted">ARIA introduces a new paradigm. By integrating directly into your daily operations, ARIA acts as an intelligent assistant that listens, structures, and organizes information securely—allowing teams to focus on public service rather than paperwork.</p>
        </div>
        <div class="story-block">
          <span class="label">Expected Impact</span>
          <h2 class="h3">Benefits</h2>
          <p class="body text-muted">Experience less manual documentation, better knowledge continuity, faster administrative processes, and more organized collaboration across departments.</p>
        </div>
      </div>
    </Container>
  </Section>

  {/* C. Key Features */}
  <Section type="feature" aria-labelledby="features-heading">
    <Container size="xl">
      <div class="section-header">
        <span class="label">Key Features</span>
        <h2 id="features-heading" class="h2">Flagship Capabilities</h2>
      </div>
      <div class="grid-4 features-grid">
        <Card variant="default">
          <h3 class="h4">Meeting Intelligence</h3>
          <p class="body text-muted">Automatically organize meetings into structured notes and action items.</p>
        </Card>
        <Card variant="default">
          <h3 class="h4">Knowledge Management</h3>
          <p class="body text-muted">Build an institutional knowledge base that remains searchable and reusable.</p>
        </Card>
        <Card variant="default">
          <h3 class="h4">Document Automation</h3>
          <p class="body text-muted">Accelerate administrative document creation using AI-assisted workflows.</p>
        </Card>
        <Card variant="default">
          <h3 class="h4">AI Workspace</h3>
          <p class="body text-muted">A centralized workspace for meetings, documents, and organizational knowledge.</p>
        </Card>
      </div>
    </Container>
  </Section>

  {/* D. Target Users & Value Proposition */}
  <Section type="content" aria-labelledby="target-heading">
    <Container size="xl">
      <div class="grid-2 target-grid">
        <div class="target-users">
          <span class="label">Target Users</span>
          <h2 id="target-heading" class="h2">Built for the Public Sector</h2>
          <ul class="user-list body-lg text-muted">
            <li>Government Agencies</li>
            <li>Inspectorates</li>
            <li>Public Sector Teams</li>
            <li>Knowledge Workers</li>
          </ul>
        </div>
        <div class="value-prop">
          <span class="label">Value Proposition</span>
          <h2 class="h2">Measurable Outcomes</h2>
          <ul class="value-list body-lg text-muted">
            <li>Less manual documentation</li>
            <li>Better knowledge continuity</li>
            <li>Faster administrative processes</li>
            <li>More organized collaboration</li>
          </ul>
        </div>
      </div>
    </Container>
  </Section>

  {/* E. Call to Action */}
  <Section type="cta" aria-labelledby="cta-heading" class="aria-cta">
    <Container size="xl" class="center-container">
      <div class="cta-badge-wrapper">
        <Badge variant="warning">Early Version</Badge>
      </div>
      <h2 id="cta-heading" class="h2 text-surface text-center">Experience ARIA</h2>
      <p class="body-lg text-surface-muted max-reading text-center">Discover how AI-assisted workflows can transform your agency's operations.</p>
      <div class="cta-actions">
        <a href="mailto:demo@kat.on" class="btn-primary">Request a Demo</a>
        <a href="/contact" class="btn-secondary-light">Contact kat.on</a>
      </div>
    </Container>
  </Section>

</BaseLayout>

<style>
  /* Use global typography and layout tokens, only scoped layout tweaks here */
  
  .center-container {
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  
  .aria-badges {
    display: flex;
    justify-content: center;
    gap: var(--space-8);
    margin-block-end: var(--space-24);
    flex-wrap: wrap;
  }

  .hero-desc {
    margin-block-start: var(--space-16);
  }

  .text-muted {
    color: var(--color-text-secondary);
  }

  .story-section {
    background-color: var(--color-surface);
  }

  .story-grid {
    display: grid;
    gap: var(--space-32);
    grid-template-columns: 1fr;
  }

  @media (min-width: 768px) {
    .story-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .story-block {
    display: flex;
    flex-direction: column;
  }
  
  .story-block .label {
    margin-block-end: var(--space-8);
    color: var(--color-accent);
  }
  
  .story-block .h3 {
    margin-block-start: 0;
    margin-block-end: var(--space-16);
  }

  .section-header {
    margin-block-end: var(--space-32);
  }
  
  .section-header .h2 {
    margin-block-start: var(--space-8);
  }

  .target-grid {
    gap: var(--space-64);
  }

  .user-list, .value-list {
    margin-block-start: var(--space-24);
    padding-inline-start: var(--space-24);
    display: flex;
    flex-direction: column;
    gap: var(--space-12);
  }

  .aria-cta {
    background-color: var(--color-primary);
  }
  
  .cta-badge-wrapper {
    margin-block-end: var(--space-16);
  }

  .text-surface {
    color: var(--color-surface);
    margin-block-start: 0;
  }

  .text-surface-muted {
    color: var(--color-muted);
    margin-block-end: var(--space-32);
  }

  .cta-actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-16);
  }

  .btn-primary, .btn-secondary-light {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: var(--space-48);
    padding-inline: var(--space-24);
    font-family: var(--font-primary);
    font-size: var(--text-body);
    font-weight: var(--weight-medium);
    text-decoration: none;
    border-radius: var(--radius-medium);
    transition: all var(--motion-fast);
  }

  .btn-primary {
    background-color: var(--color-accent);
    color: var(--color-surface);
    border: 2px solid var(--color-accent);
  }

  .btn-primary:hover {
    opacity: 0.9;
  }
  
  .btn-primary:focus-visible, .btn-secondary-light:focus-visible {
    outline: 2px solid var(--color-surface);
    outline-offset: 2px;
  }

  .btn-secondary-light {
    background-color: transparent;
    color: var(--color-surface);
    border: var(--border-thin);
    border-color: var(--color-surface);
  }

  .btn-secondary-light:hover {
    background-color: rgba(255, 255, 255, 0.1);
  }
</style>
