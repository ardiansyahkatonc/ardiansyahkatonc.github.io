---
import { buildPageMeta, SEO } from '../config/seo';
import { BRAND } from '../config/brand';
import { getLangFromUrl, useTranslations } from '../i18n';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import ThemeProvider from '../components/common/ThemeProvider.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const { title, description, image } = Astro.props;

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const meta = buildPageMeta({
  title,
  description,
  image,
  pathname: Astro.url.pathname,
  lang,
});

// Structured data (JSON-LD) — Organization + WebSite for richer search results.
const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      '@id': `${SEO.siteUrl}/#organization`,
      name: BRAND.name,
      url: SEO.siteUrl,
      description: BRAND.description,
      foundingDate: String(BRAND.launchYear),
      logo: new URL('/brand/katon/logo/katon-full.svg', SEO.siteUrl).toString(),
      sameAs: [BRAND.social.github, BRAND.social.linkedin, BRAND.social.instagram],
    },
    {
      '@type': 'WebSite',
      '@id': `${SEO.siteUrl}/#website`,
      name: BRAND.name,
      url: SEO.siteUrl,
      inLanguage: meta.lang,
      publisher: { '@id': `${SEO.siteUrl}/#organization` },
    },
  ],
};
---

<!DOCTYPE html>
<html lang={meta.lang} data-lang={meta.lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- No-flash theme bootstrap (must run before paint) -->
    <ThemeProvider />

    <!-- Google Fonts — preconnect + non-blocking stylesheet link (was a
         render-blocking CSS @import). display=swap avoids invisible text. -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
    />

    <!-- SEO -->
    <title>{meta.pageTitle}</title>
    <meta name="description" content={meta.description} />
    <meta name="author" content={meta.author} />
    <link rel="canonical" href={meta.canonical} />
    {meta.alternates.map((alt) => (
      <link rel="alternate" hreflang={alt.hreflang} href={alt.href} />
    ))}

    <!-- Open Graph -->
    <meta property="og:type" content={meta.ogType} />
    <meta property="og:title" content={meta.pageTitle} />
    <meta property="og:description" content={meta.description} />
    <meta property="og:url" content={meta.canonical} />
    <meta property="og:image" content={meta.ogImage} />
    <meta property="og:site_name" content={meta.siteName} />
    <meta property="og:locale" content={meta.ogLocale} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content={meta.twitterHandle} />
    <meta name="twitter:title" content={meta.pageTitle} />
    <meta name="twitter:description" content={meta.description} />
    <meta name="twitter:image" content={meta.ogImage} />

    <!-- Structured data -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} is:inline />

    <!-- Progressive enhancement: scroll-reveal starts hidden and is revealed by
         JS. Without JS, show all content immediately. -->
    <noscript>
      <style>
        .reveal { opacity: 1 !important; transform: none !important; }
      </style>
    </noscript>

    <!-- Favicon / PWA -->
    <!-- TODO: derive favicon.svg/.ico from the official kat.on mark
         (public/brand/katon/logo/katon-full.svg) on a brand-navy tile so it
         stays visible on light browser tabs. Current icons are a clean vector
         placeholder. -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate icon" href="/favicon.ico" sizes="any" />
    <link rel="apple-touch-icon" href="/brand/katon/favicon/apple-touch-icon.svg" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#F8FAFC" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#0B1120" media="(prefers-color-scheme: dark)" />
  </head>
  <body>
    <a href="#main-content" class="skip-link">{t('a11y.skip')}</a>
    <div class="layout-wrapper">
      <Header />
      <main id="main-content" class="main-content" tabindex="-1">
        <slot />
      </main>
      <Footer />
    </div>

    <!-- Theme engine + scroll reveal -->
    <script>
      import { initTheme } from '../scripts/theme';
      initTheme();

      document.addEventListener('DOMContentLoaded', () => {
        const observer = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) entry.target.classList.add('active');
          });
        }, { threshold: 0.08, rootMargin: '0px 0px -40px 0px' });
        document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));
      });
    </script>
  </body>
</html>
