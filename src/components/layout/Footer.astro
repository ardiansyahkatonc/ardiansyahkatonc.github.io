---
import { brand } from '../../config/brand';
import { social } from '../../config/social';

const currentYear = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container-xl footer-inner">
    <div class="footer-brand">
      <p class="brand-name">{brand.name}</p>
      <p class="brand-tagline text-muted">{brand.tagline}</p>
    </div>
    
    <div class="footer-grid">
      
      <div class="footer-column">
        <h3 class="footer-heading label">Products</h3>
        <ul class="footer-links">
          <li><a href="/aria" class="footer-link">ARIA Flagship</a></li>
          <li><a href="/projects" class="footer-link">Ecosystem</a></li>
        </ul>
      </div>

      <div class="footer-column">
        <h3 class="footer-heading label">Company</h3>
        <ul class="footer-links">
          <li><a href="/about" class="footer-link">About</a></li>
          <li><a href="/contact" class="footer-link">Partnerships</a></li>
        </ul>
      </div>

      <div class="footer-column">
        <h3 class="footer-heading label">Connect</h3>
        <ul class="footer-links">
          <li><a href={social.github} class="footer-link" target="_blank" rel="noopener noreferrer">GitHub</a></li>
          <li><a href={social.linkedin} class="footer-link" target="_blank" rel="noopener noreferrer">LinkedIn</a></li>
          <li><a href={social.instagram} class="footer-link" target="_blank" rel="noopener noreferrer">Instagram</a></li>
          <li><a href={social.email} class="footer-link">Email</a></li>
        </ul>
      </div>

    </div>
  </div>
  
  <div class="container-xl footer-bottom">
    <p class="copyright">&copy; {currentYear} {brand.name}. All rights reserved. <span class="divider">|</span> AI-Native Product Studio</p>
  </div>
</footer>

<style>
  .site-footer {
    background-color: var(--color-surface-muted);
    border-top: var(--border-light);
    padding-block-start: var(--space-64);
    padding-block-end: var(--space-32);
    margin-top: auto;
  }
  
  .footer-inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-64);
    margin-bottom: var(--space-48);
  }
  
  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
  }
  
  .brand-name {
    font-size: var(--text-h4);
    font-weight: var(--weight-bold);
    letter-spacing: -0.02em;
    color: var(--color-primary);
    margin: 0;
  }
  
  .brand-tagline {
    color: var(--color-text-secondary);
    font-size: var(--text-body);
    margin: 0;
    max-width: 30ch;
  }

  .text-muted {
    color: var(--color-text-secondary);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-48);
  }
  
  .footer-heading {
    margin-block-end: var(--space-16);
    color: var(--color-text-primary);
  }
  
  .footer-links {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-12);
    padding: 0;
    margin: 0;
  }
  
  .footer-link {
    color: var(--color-text-secondary);
    text-decoration: none;
    font-size: var(--text-body);
    transition: color var(--motion-fast);
  }
  
  .footer-link:hover,
  .footer-link:focus-visible {
    color: var(--color-primary);
  }
  
  .footer-bottom {
    border-top: var(--border-light);
    padding-block-start: var(--space-32);
  }
  
  .copyright {
    color: var(--color-muted);
    font-size: var(--text-caption);
    text-align: left;
    margin: 0;
  }

  .divider {
    margin-inline: var(--space-8);
    opacity: 0.5;
  }

  @media (min-width: 768px) {
    .site-footer {
      padding-block-start: var(--space-96);
      padding-block-end: var(--space-48);
    }
    
    .footer-inner {
      flex-direction: row;
      justify-content: space-between;
      align-items: flex-start;
      margin-bottom: var(--space-96);
    }
    
    .footer-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: var(--space-80);
    }
    
    .footer-brand {
      max-width: 300px;
    }
  }
</style>
