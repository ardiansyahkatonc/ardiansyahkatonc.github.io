---
import { BRAND } from '../../config/brand';
import { social } from '../../config/social';
import Logo from '../common/Logo.astro';
import { getLangFromUrl, useTranslations, localizePath } from '../../i18n';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const currentYear = new Date().getFullYear();
const buildVersion = 'v1.0.0';
const lastUpdated = '2026-07-15';
---

<footer class="site-footer" id="site-footer">
  <div class="container-xl footer-main">
    
    <!-- Brand Column -->
    <div class="footer-brand">
      <div class="footer-logo-group">
        <Logo variant="full" size="md" />
      </div>
      <p class="footer-brand-tagline">{BRAND.tagline} · {BRAND.country}</p>
      <p class="footer-statement">{t('footer.statement')}</p>
      <div class="footer-meta">
        <span class="meta-badge">
          <span class="meta-dot active"></span>
          {t('footer.build')} {buildVersion}
        </span>
        <span class="meta-badge">{t('footer.updated')} {lastUpdated}</span>
        <span class="meta-badge"><span id="footer-visitors">—</span> {t('footer.visits')}</span>
      </div>
    </div>

    <!-- Navigation Grid -->
    <div class="footer-nav-grid">

      <div class="footer-col">
        <h3 class="footer-col-heading">{t('footer.products')}</h3>
        <ul class="footer-link-list">
          <li><a href={localizePath('/aria', lang)} class="footer-link">ARIA <span class="footer-link-badge">{t('footer.flagship')}</span></a></li>
          <li><a href={localizePath('/projects', lang)} class="footer-link">{t('footer.link.ecosystem')}</a></li>
        </ul>
      </div>

      <div class="footer-col">
        <h3 class="footer-col-heading">{t('footer.company')}</h3>
        <ul class="footer-link-list">
          <li><a href={localizePath('/about', lang)} class="footer-link">{t('footer.link.about')}</a></li>
          <li><a href={localizePath('/contact', lang)} class="footer-link">{t('footer.link.partnerships')}</a></li>
        </ul>
      </div>

      <div class="footer-col">
        <h3 class="footer-col-heading">{t('footer.resources')}</h3>
        <ul class="footer-link-list">
          <li><a href={localizePath('/aria#capabilities', lang)} class="footer-link">{t('footer.link.docs')}</a></li>
          <li><a href={localizePath('/aria#roadmap', lang)} class="footer-link">{t('footer.link.roadmap')}</a></li>
        </ul>
      </div>

      <div class="footer-col">
        <h3 class="footer-col-heading">{t('footer.social')}</h3>
        <ul class="footer-link-list">
          <li><a href={social.whatsapp} class="footer-link" target="_blank" rel="noopener noreferrer">WhatsApp</a></li>
          <li><a href={social.github} class="footer-link" target="_blank" rel="noopener noreferrer">GitHub</a></li>
          <li><a href={social.linkedin} class="footer-link" target="_blank" rel="noopener noreferrer">LinkedIn</a></li>
          <li><a href={social.instagram} class="footer-link" target="_blank" rel="noopener noreferrer">Instagram</a></li>
          <li><a href={social.email} class="footer-link">{t('contact.email')}</a></li>
        </ul>
      </div>

    </div>
  </div>

  <!-- Footer Bottom Row -->
  <div class="container-xl footer-bottom">
    <p class="footer-copyright">&copy; {currentYear} {BRAND.name}. {t('footer.copyright')}</p>
    <button class="back-to-top" id="back-to-top" aria-label="Back to top">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path d="M18 15l-6-6-6 6"/>
      </svg>
    </button>
  </div>
</footer>

<script>
  // Visitor placeholder — local, privacy-friendly (no network). Seeds a base
  // number and increments once per browser so the footer feels alive.
  (() => {
    const el = document.getElementById('footer-visitors');
    if (!el) return;
    const KEY = 'katon-visits';
    const base = 1240;
    let n = parseInt(localStorage.getItem(KEY) || '', 10);
    if (!Number.isFinite(n)) n = base + Math.floor(Math.random() * 60);
    n += 1;
    localStorage.setItem(KEY, String(n));
    el.textContent = n.toLocaleString('en-US');
  })();

  // Back to Top
  const backToTopBtn = document.getElementById('back-to-top');
  const footerEl = document.getElementById('site-footer');
  
  if (backToTopBtn && footerEl) {
    backToTopBtn.addEventListener('click', () => {
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });
    
    // Show/hide based on scroll position
    window.addEventListener('scroll', () => {
      if (window.scrollY > 500) {
        backToTopBtn.classList.add('visible');
      } else {
        backToTopBtn.classList.remove('visible');
      }
    }, { passive: true });
  }
</script>

<style>
  .site-footer {
    background-color: var(--color-surface);
    border-top: var(--border-light);
    padding-block-start: var(--space-80);
  }

  .footer-main {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-64);
    margin-block-end: var(--space-64);
  }

  @media (min-width: 768px) {
    .footer-main {
      grid-template-columns: 1fr 2fr;
      gap: var(--space-96);
    }
  }

  /* Brand */
  .footer-logo-group {
    display: flex;
    align-items: center;
    gap: var(--space-12);
    margin-block-end: var(--space-12);
  }

  .footer-logo {
    width: 28px;
    height: 28px;
    flex-shrink: 0;
  }

  .footer-brand-name {
    font-size: var(--text-body);
    font-weight: var(--weight-bold);
    letter-spacing: -0.02em;
    color: var(--color-primary);
  }

  .footer-brand-tagline {
    font-size: var(--text-caption);
    color: var(--color-text-secondary);
    margin-block-start: var(--space-16);
    margin-block-end: var(--space-12);
  }

  .footer-statement {
    font-size: var(--text-caption);
    line-height: 1.6;
    color: var(--color-muted);
    max-width: 34ch;
    margin-block-end: var(--space-24);
  }

  .footer-meta {
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
  }

  .meta-badge {
    display: inline-flex;
    align-items: center;
    gap: var(--space-8);
    font-size: var(--text-label);
    color: var(--color-muted);
    font-family: var(--font-mono);
  }

  .meta-dot {
    width: 6px;
    height: 6px;
    border-radius: var(--radius-full);
    background: var(--color-border);
  }

  .meta-dot.active {
    background: var(--color-success);
  }

  /* Nav Grid */
  .footer-nav-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-48);
  }

  @media (min-width: 768px) {
    .footer-nav-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .footer-col-heading {
    font-size: var(--text-label);
    font-weight: var(--weight-semibold);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-primary);
    margin-block-start: 0;
    margin-block-end: var(--space-16);
  }

  .footer-link-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-12);
  }

  .footer-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-8);
    color: var(--color-text-secondary);
    text-decoration: none;
    font-size: var(--text-caption);
    transition: color var(--motion-fast);
  }

  .footer-link:hover {
    color: var(--color-primary);
  }

  .footer-link-badge {
    font-size: 10px;
    font-weight: var(--weight-semibold);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 2px 6px;
    border-radius: var(--radius-full);
    background: rgba(37, 99, 235, 0.1);
    color: var(--color-accent);
  }

  /* Bottom row */
  .footer-bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-block: var(--space-24);
    border-top: var(--border-light);
  }

  .footer-copyright {
    font-size: var(--text-label);
    color: var(--color-muted);
    margin: 0;
  }

  /* Back to Top (Floating) */
  .back-to-top {
    width: 40px;
    height: 40px;
    border-radius: var(--radius-full);
    background: var(--color-primary);
    color: var(--color-surface);
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transform: translateY(8px);
    transition: all var(--motion-normal);
    pointer-events: none;
  }

  .back-to-top.visible {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }

  .back-to-top:hover {
    background: var(--color-accent);
    transform: translateY(-2px);
  }

  .back-to-top svg {
    width: 18px;
    height: 18px;
  }
</style>
