---
import { brand } from '../../config/brand';
import { navigation } from '../../config/navigation';
import { social } from '../../config/social';

const currentYear = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container-xl footer-inner">
    <div class="footer-brand">
      <p class="brand-name">{brand.name}</p>
      <p class="brand-tagline text-muted max-reading">{brand.tagline}</p>
    </div>
    
    <div class="footer-navigation">
      <nav aria-label="Footer Navigation" class="footer-nav">
        <h3 class="footer-heading label">Menu</h3>
        <ul class="footer-links">
          {navigation.map((item) => (
            <li>
              <a href={item.href} class="footer-link">{item.name}</a>
            </li>
          ))}
        </ul>
      </nav>
      
      <div class="footer-social">
        <h3 class="footer-heading label">Connect</h3>
        <ul class="footer-links">
          <li><a href={social.github} aria-label="GitHub" class="footer-link" target="_blank" rel="noopener noreferrer">GitHub</a></li>
          <li><a href={social.linkedin} aria-label="LinkedIn" class="footer-link" target="_blank" rel="noopener noreferrer">LinkedIn</a></li>
          <li><a href={social.instagram} aria-label="Instagram" class="footer-link" target="_blank" rel="noopener noreferrer">Instagram</a></li>
          <li><a href={social.email} aria-label="Email" class="footer-link">Email</a></li>
        </ul>
      </div>
    </div>
  </div>
  
  <div class="container-xl footer-bottom">
    <p class="copyright">&copy; {currentYear} {brand.name}. All rights reserved.</p>
  </div>
</footer>

<style>
  .site-footer {
    background-color: var(--color-surface-muted);
    border-top: var(--border-light);
    padding-block-start: var(--space-64);
    padding-block-end: var(--space-32);
    margin-top: auto;
  }
  
  .footer-inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-48);
    margin-bottom: var(--space-48);
  }
  
  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
  }
  
  .brand-name {
    font-size: var(--text-h4);
    font-weight: var(--weight-bold);
    letter-spacing: -0.02em;
    color: var(--color-primary);
    margin: 0;
  }
  
  .brand-tagline {
    color: var(--color-text-secondary);
    font-size: var(--text-body);
    margin: 0;
  }

  .text-muted {
    color: var(--color-text-secondary);
  }

  .footer-navigation {
    display: flex;
    flex-direction: column;
    gap: var(--space-32);
  }
  
  .footer-heading {
    margin-block-end: var(--space-16);
    color: var(--color-text-primary);
  }
  
  .footer-links {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-12);
    padding: 0;
    margin: 0;
  }
  
  .footer-link {
    color: var(--color-text-secondary);
    text-decoration: none;
    font-size: var(--text-body);
    transition: color var(--motion-fast);
  }
  
  .footer-link:hover,
  .footer-link:focus-visible {
    color: var(--color-primary);
  }
  
  .footer-bottom {
    border-top: var(--border-light);
    padding-block-start: var(--space-32);
  }
  
  .copyright {
    color: var(--color-muted);
    font-size: var(--text-caption);
    text-align: left;
    margin: 0;
  }

  @media (min-width: 768px) {
    .site-footer {
      padding-block-start: var(--space-96);
      padding-block-end: var(--space-48);
    }
    
    .footer-inner {
      flex-direction: row;
      justify-content: space-between;
      align-items: flex-start;
      margin-bottom: var(--space-64);
    }
    
    .footer-navigation {
      flex-direction: row;
      gap: var(--space-64);
    }
    
    .footer-brand {
      max-width: 300px;
    }
  }
</style>
