---
interface Props {
  class?: string;
}
const { class: className = '' } = Astro.props;
---

<svg class={`katon-logo ${className}`} viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg" aria-label="kat.on Logo">
  <rect x="2" y="2" width="28" height="28" rx="6" fill="var(--color-primary)" />
  <path d="M10 8V24" stroke="var(--color-surface)" stroke-width="3" stroke-linecap="round" />
  <path d="M22 8L12 16L22 24" stroke="var(--color-surface)" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" />
</svg>

<style>
  .katon-logo {
    width: 32px;
    height: 32px;
    display: block;
    transition: transform var(--motion-fast);
  }
  
  .katon-logo:hover {
    transform: scale(1.05);
  }
</style>
