---
interface Props {
  class?: string;
}
const { class: className = '' } = Astro.props;
---
<div class={`premium-mockup-wrapper ${className}`}>
  <!-- Glow behind mockup -->
  <div class="mockup-glow primary"></div>
  <div class="mockup-glow secondary"></div>

  <!-- The Main Dashboard Frame -->
  <div class="premium-mockup reveal animate-slide-up">
    <!-- Sidebar -->
    <aside class="mockup-sidebar">
      <div class="sidebar-header">
        <div class="skel-logo"></div>
        <div class="skel-line w-16"></div>
      </div>
      <div class="sidebar-nav">
        <div class="skel-nav-item active"></div>
        <div class="skel-nav-item"></div>
        <div class="skel-nav-item"></div>
      </div>
    </aside>

    <!-- Main Content -->
    <main class="mockup-main">
      <header class="mockup-topbar">
        <div class="skel-line w-32"></div>
        <div class="skel-avatar"></div>
      </header>
      
      <div class="mockup-content">
        <div class="content-grid">
          <!-- Calendar/Meeting Card -->
          <div class="mockup-card floating-card delay-1">
            <div class="card-header">
              <div class="skel-icon bg-blue"></div>
              <div class="skel-line w-24"></div>
            </div>
            <div class="skel-line w-full mt-12"></div>
            <div class="skel-line w-3/4 mt-4"></div>
          </div>
          
          <!-- Knowledge/AI Card -->
          <div class="mockup-card floating-card delay-2">
            <div class="card-header">
              <div class="skel-icon bg-green"></div>
              <div class="skel-line w-24"></div>
            </div>
            <div class="skel-line w-full mt-12"></div>
            <div class="skel-line w-5/6 mt-4"></div>
          </div>
        </div>

        <!-- Large Workspace Area -->
        <div class="mockup-card large-card floating-card delay-3 mt-16">
          <div class="card-header border-b pb-8 mb-8">
            <div class="skel-line w-48"></div>
            <div class="skel-badge"></div>
          </div>
          <div class="skel-line w-full"></div>
          <div class="skel-line w-full mt-4"></div>
          <div class="skel-line w-3/4 mt-4"></div>
          <div class="skel-line w-4/5 mt-4"></div>
        </div>
      </div>
    </main>
  </div>
</div>

<style>
  .premium-mockup-wrapper {
    position: relative;
    width: 100%;
    aspect-ratio: 16/10;
    max-width: 700px;
    margin: 0 auto;
    perspective: 1000px;
  }

  .mockup-glow {
    position: absolute;
    border-radius: var(--radius-full);
    filter: blur(80px);
    z-index: 0;
  }

  .mockup-glow.primary {
    top: 20%;
    right: 10%;
    width: 300px;
    height: 300px;
    background: rgba(37, 99, 235, 0.15); /* Accent Glow */
  }

  .mockup-glow.secondary {
    bottom: 10%;
    left: 10%;
    width: 250px;
    height: 250px;
    background: rgba(15, 23, 42, 0.08); /* Primary Glow */
  }

  .premium-mockup {
    position: relative;
    z-index: 10;
    display: flex;
    width: 100%;
    height: 100%;
    background: rgba(255, 255, 255, 0.7);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    border: 1px solid rgba(255, 255, 255, 0.8);
    border-radius: var(--radius-2xl);
    box-shadow: var(--shadow-xl);
    overflow: hidden;
    transform: rotateX(2deg) rotateY(-4deg) translateY(10px);
    transform-style: preserve-3d;
    transition: transform var(--motion-slow);
  }

  .premium-mockup:hover {
    transform: rotateX(0) rotateY(0) translateY(0);
  }

  /* Skeleton Layout */
  .mockup-sidebar {
    width: 25%;
    background: rgba(248, 250, 252, 0.6);
    border-right: 1px solid rgba(15, 23, 42, 0.04);
    padding: var(--space-16);
    display: flex;
    flex-direction: column;
    gap: var(--space-24);
  }

  .sidebar-header {
    display: flex;
    align-items: center;
    gap: var(--space-8);
  }

  .skel-logo {
    width: 20px;
    height: 20px;
    background: var(--color-primary);
    border-radius: 4px;
  }

  .sidebar-nav {
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
  }

  .skel-nav-item {
    height: 24px;
    border-radius: 4px;
    background: rgba(15, 23, 42, 0.04);
  }

  .skel-nav-item.active {
    background: rgba(37, 99, 235, 0.08);
  }

  .mockup-main {
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .mockup-topbar {
    height: 56px;
    border-bottom: 1px solid rgba(15, 23, 42, 0.04);
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 var(--space-24);
  }

  .skel-avatar {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: rgba(15, 23, 42, 0.06);
  }

  .mockup-content {
    padding: var(--space-24);
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .content-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-16);
  }

  .mockup-card {
    background: var(--color-surface);
    border: 1px solid rgba(15, 23, 42, 0.04);
    border-radius: var(--radius-large);
    padding: var(--space-16);
    box-shadow: var(--shadow-sm);
  }

  .large-card {
    flex: 1;
  }

  .floating-card {
    animation: float 6s ease-in-out infinite;
  }

  .delay-1 { animation-delay: 0s; }
  .delay-2 { animation-delay: -2s; }
  .delay-3 { animation-delay: -4s; }

  @keyframes float {
    0% { transform: translateY(0px); }
    50% { transform: translateY(-4px); }
    100% { transform: translateY(0px); }
  }

  .card-header {
    display: flex;
    align-items: center;
    gap: var(--space-8);
  }

  .border-b { border-bottom: 1px solid rgba(15, 23, 42, 0.04); }
  .pb-8 { padding-bottom: 8px; }
  .mb-8 { margin-bottom: 8px; }
  .mt-4 { margin-top: 4px; }
  .mt-12 { margin-top: 12px; }
  .mt-16 { margin-top: 16px; }

  .skel-icon {
    width: 24px;
    height: 24px;
    border-radius: 6px;
  }

  .bg-blue { background: rgba(37, 99, 235, 0.15); }
  .bg-green { background: rgba(22, 163, 74, 0.15); }

  .skel-line { height: 10px; background: rgba(15, 23, 42, 0.06); border-radius: 4px; }
  .skel-badge { height: 20px; width: 60px; background: rgba(37, 99, 235, 0.1); border-radius: 10px; margin-left: auto; }

  .w-16 { width: 64px; }
  .w-24 { width: 96px; }
  .w-32 { width: 128px; }
  .w-48 { width: 192px; }
  .w-full { width: 100%; }
  .w-3\/4 { width: 75%; }
  .w-4\/5 { width: 80%; }
  .w-5\/6 { width: 83.333%; }
  
  @media (max-width: 768px) {
    .premium-mockup {
      transform: none;
    }
  }
</style>
