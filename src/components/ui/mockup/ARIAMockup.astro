---
---
<div class="aria-mockup" aria-hidden="true">
  <!-- Sidebar -->
  <aside class="mockup-sidebar">
    <div class="mockup-brand">
      <div class="mockup-logo"></div>
      <div class="mockup-brand-text"></div>
    </div>
    <div class="mockup-nav">
      <div class="mockup-nav-item active"></div>
      <div class="mockup-nav-item"></div>
      <div class="mockup-nav-item"></div>
      <div class="mockup-nav-item"></div>
    </div>
    <div class="mockup-bottom-nav">
      <div class="mockup-nav-item"></div>
    </div>
  </aside>

  <!-- Main Workspace -->
  <main class="mockup-main">
    <header class="mockup-header">
      <div class="mockup-search"></div>
      <div class="mockup-user"></div>
    </header>

    <div class="mockup-content">
      <!-- Meeting Panel -->
      <div class="mockup-panel panel-large">
        <div class="mockup-panel-header">
          <div class="mockup-title-skeleton"></div>
          <div class="mockup-badge-skeleton"></div>
        </div>
        <div class="mockup-text-lines">
          <div class="mockup-line w-full"></div>
          <div class="mockup-line w-3/4"></div>
          <div class="mockup-line w-5/6"></div>
          <div class="mockup-line w-2/3"></div>
        </div>
        
        <div class="mockup-cards">
          <div class="mockup-card">
            <div class="mockup-card-icon"></div>
            <div class="mockup-card-text"></div>
          </div>
          <div class="mockup-card">
            <div class="mockup-card-icon"></div>
            <div class="mockup-card-text"></div>
          </div>
        </div>
      </div>

      <!-- Side Panels -->
      <div class="mockup-side-panels">
        <!-- AI Assistant Panel -->
        <div class="mockup-panel panel-ai">
          <div class="mockup-ai-header">
            <div class="mockup-ai-icon"></div>
            <div class="mockup-title-skeleton small"></div>
          </div>
          <div class="mockup-ai-chat">
            <div class="mockup-chat-bubble user"></div>
            <div class="mockup-chat-bubble ai">
              <div class="mockup-line w-full"></div>
              <div class="mockup-line w-4/5"></div>
            </div>
          </div>
          <div class="mockup-ai-input"></div>
        </div>

        <!-- Task Panel -->
        <div class="mockup-panel panel-small">
          <div class="mockup-title-skeleton small mb-12"></div>
          <div class="mockup-task-item">
            <div class="mockup-checkbox"></div>
            <div class="mockup-line w-3/4"></div>
          </div>
          <div class="mockup-task-item">
            <div class="mockup-checkbox checked"></div>
            <div class="mockup-line w-1/2"></div>
          </div>
          <div class="mockup-task-item">
            <div class="mockup-checkbox"></div>
            <div class="mockup-line w-5/6"></div>
          </div>
        </div>
      </div>
    </div>
  </main>
</div>

<style>
  .aria-mockup {
    display: flex;
    width: 100%;
    height: 600px;
    background-color: var(--color-surface);
    border: var(--border-light);
    border-radius: var(--radius-xl);
    overflow: hidden;
    box-shadow: var(--shadow-xl);
    font-family: var(--font-primary);
  }

  /* Skeleton Colors */
  :root {
    --skel-base: rgba(15, 23, 42, 0.05);
    --skel-dark: rgba(15, 23, 42, 0.1);
    --skel-accent: var(--color-accent);
    --skel-accent-light: rgba(15, 23, 42, 0.1);
  }

  /* Sidebar */
  .mockup-sidebar {
    width: 240px;
    background-color: var(--color-surface-muted);
    border-right: var(--border-light);
    display: flex;
    flex-direction: column;
    padding: var(--space-24) var(--space-16);
    flex-shrink: 0;
  }

  .mockup-brand {
    display: flex;
    align-items: center;
    gap: var(--space-12);
    margin-bottom: var(--space-48);
  }

  .mockup-logo {
    width: 24px;
    height: 24px;
    border-radius: var(--radius-small);
    background-color: var(--skel-accent);
  }

  .mockup-brand-text {
    height: 16px;
    width: 80px;
    background-color: var(--skel-dark);
    border-radius: var(--radius-small);
  }

  .mockup-nav {
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
    flex: 1;
  }

  .mockup-nav-item {
    height: 32px;
    width: 100%;
    background-color: var(--skel-base);
    border-radius: var(--radius-small);
  }

  .mockup-nav-item.active {
    background-color: var(--skel-accent-light);
  }

  .mockup-bottom-nav {
    margin-top: auto;
  }

  /* Main Workspace */
  .mockup-main {
    flex: 1;
    display: flex;
    flex-direction: column;
    min-width: 0;
    background-color: #fafafa;
  }

  .mockup-header {
    height: 64px;
    border-bottom: var(--border-light);
    background-color: var(--color-surface);
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 var(--space-32);
    flex-shrink: 0;
  }

  .mockup-search {
    width: 240px;
    height: 32px;
    background-color: var(--skel-base);
    border-radius: var(--radius-full);
  }

  .mockup-user {
    width: 32px;
    height: 32px;
    background-color: var(--skel-dark);
    border-radius: var(--radius-full);
  }

  .mockup-content {
    padding: var(--space-32);
    display: flex;
    gap: var(--space-24);
    flex: 1;
    overflow-y: auto;
  }

  /* Panels */
  .mockup-panel {
    background-color: var(--color-surface);
    border: var(--border-light);
    border-radius: var(--radius-lg);
    padding: var(--space-24);
    box-shadow: var(--shadow-sm);
  }

  .panel-large {
    flex: 2;
    display: flex;
    flex-direction: column;
    gap: var(--space-32);
  }

  .mockup-side-panels {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: var(--space-24);
  }

  .panel-ai {
    flex: 3;
    display: flex;
    flex-direction: column;
  }

  .panel-small {
    flex: 2;
  }

  /* Skeleton Elements */
  .mockup-panel-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
  }

  .mockup-title-skeleton {
    height: 24px;
    width: 200px;
    background-color: var(--skel-dark);
    border-radius: var(--radius-small);
  }
  
  .mockup-title-skeleton.small {
    height: 16px;
    width: 120px;
  }

  .mockup-badge-skeleton {
    height: 24px;
    width: 80px;
    background-color: var(--skel-accent-light);
    border-radius: var(--radius-full);
  }

  .mockup-text-lines {
    display: flex;
    flex-direction: column;
    gap: var(--space-12);
  }

  .mockup-line {
    height: 12px;
    background-color: var(--skel-base);
    border-radius: var(--radius-small);
  }

  .w-full { width: 100%; }
  .w-5\/6 { width: 83.333%; }
  .w-4\/5 { width: 80%; }
  .w-3\/4 { width: 75%; }
  .w-2\/3 { width: 66.666%; }
  .w-1\/2 { width: 50%; }

  .mockup-cards {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-16);
    margin-top: auto;
  }

  .mockup-card {
    border: var(--border-light);
    border-radius: var(--radius-md);
    padding: var(--space-16);
    display: flex;
    flex-direction: column;
    gap: var(--space-12);
  }

  .mockup-card-icon {
    width: 32px;
    height: 32px;
    background-color: var(--skel-base);
    border-radius: var(--radius-small);
  }

  .mockup-card-text {
    height: 12px;
    width: 80%;
    background-color: var(--skel-dark);
    border-radius: var(--radius-small);
  }

  /* AI Panel Specific */
  .mockup-ai-header {
    display: flex;
    align-items: center;
    gap: var(--space-12);
    margin-bottom: var(--space-24);
    padding-bottom: var(--space-12);
    border-bottom: var(--border-light);
  }

  .mockup-ai-icon {
    width: 20px;
    height: 20px;
    background-color: var(--skel-accent);
    border-radius: var(--radius-full);
  }

  .mockup-ai-chat {
    display: flex;
    flex-direction: column;
    gap: var(--space-16);
    flex: 1;
  }

  .mockup-chat-bubble {
    padding: var(--space-12);
    border-radius: var(--radius-md);
    max-width: 85%;
  }

  .mockup-chat-bubble.user {
    background-color: var(--skel-base);
    align-self: flex-end;
    border-bottom-right-radius: 0;
    height: 36px;
    width: 60%;
  }

  .mockup-chat-bubble.ai {
    background-color: var(--skel-accent-light);
    align-self: flex-start;
    border-bottom-left-radius: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
    width: 90%;
  }

  .mockup-ai-input {
    height: 40px;
    border: var(--border-light);
    border-radius: var(--radius-full);
    margin-top: var(--space-16);
  }

  /* Task Panel Specific */
  .mb-12 {
    margin-bottom: var(--space-12);
  }

  .mockup-task-item {
    display: flex;
    align-items: center;
    gap: var(--space-12);
    padding: var(--space-8) 0;
  }

  .mockup-checkbox {
    width: 16px;
    height: 16px;
    border: 2px solid var(--skel-dark);
    border-radius: 4px;
    flex-shrink: 0;
  }

  .mockup-checkbox.checked {
    background-color: var(--skel-accent);
    border-color: var(--skel-accent);
  }

  /* Responsive adjustment */
  @media (max-width: 1024px) {
    .aria-mockup {
      height: 500px;
    }
    .mockup-sidebar {
      display: none;
    }
    .mockup-side-panels {
      display: none;
    }
  }
</style>
