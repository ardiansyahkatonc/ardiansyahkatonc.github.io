---
const benefits = [
  {
    stat: '80%',
    titleId: 'Pengurangan Dokumentasi Manual',
    titleEn: 'Less Manual Documentation',
    descId: 'Notulen, ringkasan, dan tindak lanjut rapat dibuat otomatis — tidak ada pekerjaan manual.',
    descEn: 'Meeting minutes, summaries, and follow-ups are created automatically — no manual work needed.',
  },
  {
    stat: '100%',
    titleId: 'Keputusan Terlacak',
    titleEn: 'Decisions Tracked',
    descId: 'Setiap keputusan penting tercatat dan dapat dicari kembali kapan saja oleh siapa saja di tim.',
    descEn: 'Every key decision is recorded and searchable at any time by anyone on the team.',
  },
  {
    stat: '∞',
    titleId: 'Pengetahuan yang Bertahan',
    titleEn: 'Knowledge That Outlives Teams',
    descId: 'Pengetahuan institusional tidak hilang saat anggota tim berganti — tersimpan permanen di ARIA.',
    descEn: 'Institutional knowledge doesn\'t disappear when team members change — permanently stored in ARIA.',
  },
];
---

<section class="section benefits-section" aria-labelledby="benefits-heading">
  <div class="container-xl">
    <div class="benefits-header reveal">
      <span class="label text-accent">
        <span data-lang-id>Dampak Nyata</span>
        <span data-lang-en style="display:none">Real Impact</span>
      </span>
      <h2 id="benefits-heading" class="section-title benefits-title">
        <span data-lang-id>Mengapa Tim Memilih ARIA</span>
        <span data-lang-en style="display:none">Why Teams Choose ARIA</span>
      </h2>
    </div>

    <div class="benefits-grid">
      {benefits.map((b, i) => (
        <div class={`benefit-card reveal reveal-delay-${i + 1}`}>
          <div class="benefit-stat">{b.stat}</div>
          <h3 class="benefit-title card-title">
            <span data-lang-id>{b.titleId}</span>
            <span data-lang-en style="display:none">{b.titleEn}</span>
          </h3>
          <p class="benefit-desc body-sm text-secondary">
            <span data-lang-id>{b.descId}</span>
            <span data-lang-en style="display:none">{b.descEn}</span>
          </p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .benefits-section {
    background: var(--color-primary);
    overflow: hidden;
    position: relative;
  }

  .benefits-section::before {
    content: '';
    position: absolute;
    width: 600px;
    height: 600px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(37,99,235,0.15) 0%, transparent 70%);
    top: -200px;
    right: -100px;
    pointer-events: none;
  }

  .benefits-header {
    margin-block-end: var(--space-64);
  }

  .text-accent { color: var(--color-accent); }

  .benefits-title {
    color: var(--color-surface);
    margin-block-start: var(--space-12);
  }

  .benefits-grid {
    display: grid;
    gap: var(--space-2);
    grid-template-columns: 1fr;
  }

  @media (min-width: 768px) {
    .benefits-grid { grid-template-columns: repeat(3, 1fr); gap: var(--space-24); }
  }

  .benefit-card {
    padding: var(--space-48) var(--space-40, 40px);
    border-radius: var(--radius-2xl);
    border: 1px solid rgba(255,255,255,0.08);
    background: rgba(255,255,255,0.04);
    transition: background var(--motion-fast), transform var(--motion-fast);
    display: flex;
    flex-direction: column;
    gap: var(--space-16);
  }

  .benefit-card:hover {
    background: rgba(255,255,255,0.07);
    transform: translateY(-4px);
  }

  .benefit-stat {
    font-size: 3.5rem;
    font-weight: var(--weight-bold);
    letter-spacing: -0.04em;
    line-height: 1;
    background: var(--gradient-accent);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .benefit-title {
    color: var(--color-surface);
    margin: 0;
  }

  .benefit-desc {
    color: rgba(255,255,255,0.55);
    margin: 0;
    line-height: 1.65;
  }

  .text-secondary { color: rgba(255,255,255,0.55); }
</style>
