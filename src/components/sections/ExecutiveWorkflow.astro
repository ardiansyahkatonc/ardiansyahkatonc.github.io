---
// Executive Workflow — the end-to-end ARIA flow that lets a visitor understand
// the product in ~10 seconds: Meeting → AI Analysis → Minutes → Google Docs →
// Approval. Paired with a realistic AI-generated minutes document (the tangible
// output). Every step maps to an established ARIA capability — nothing invented.
import { getLangFromUrl, useTranslations, localizePath } from '../../i18n';

interface Props {
  eyebrowKey?: string;
  titleKey?: string;
  subKey?: string;
}
const {
  eyebrowKey = 'workflow.eyebrow',
  titleKey = 'workflow.title',
  subKey = 'workflow.sub',
} = Astro.props;

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const steps = [
  { n: 'step1', icon: '<path d="M3 5h14v9H8l-4 3v-3H3z"/><path d="M7 8.5h6M7 11h4"/>' },
  { n: 'step2', icon: '<path d="M10 2.5l1.6 3.9 3.9 1.6-3.9 1.6L10 13.5 8.4 9.6 4.5 8l3.9-1.6z"/><path d="M15.5 13.5l.7 1.8 1.8.7-1.8.7-.7 1.8-.7-1.8-1.8-.7 1.8-.7z"/>' },
  { n: 'step3', icon: '<rect x="4" y="2.5" width="12" height="15" rx="1.5"/><path d="M7 6.5h6M7 9.5h6M7 12.5h4"/>' },
  { n: 'step4', icon: '<path d="M6 2.5h5l4 4v11a1 1 0 0 1-1 1H6a1 1 0 0 1-1-1V3.5a1 1 0 0 1 1-1z"/><path d="M11 2.5v4h4"/><path d="M7.5 10.5h5M7.5 13h5"/>' },
  { n: 'step5', icon: '<circle cx="10" cy="10" r="7.5"/><path d="M6.5 10l2.5 2.5 4.5-5"/>' },
] as const;
---
<section class="exec-workflow" aria-labelledby="workflow-heading">
  <div class="container-xl">

    <div class="workflow-head reveal">
      <span class="workflow-eyebrow label">{t(eyebrowKey as any)}</span>
      <h2 id="workflow-heading" class="section-title">{t(titleKey as any)}</h2>
      <p class="workflow-sub">{t(subKey as any)}</p>
    </div>

    <!-- 5-step flow -->
    <ol class="flow reveal" aria-label={t('workflow.eyebrow')}>
      {steps.map((s, i) => (
        <>
          <li class="flow-step">
            <span class="flow-num" aria-hidden="true">{i + 1}</span>
            <span class="flow-icon" aria-hidden="true">
              <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" set:html={s.icon} />
            </span>
            <span class="flow-title">{t(`workflow.${s.n}.title` as any)}</span>
            <span class="flow-desc">{t(`workflow.${s.n}.desc` as any)}</span>
          </li>
          {i < steps.length - 1 && <li class="flow-arrow" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg></li>}
        </>
      ))}
    </ol>

    <!-- Realistic AI-generated minutes (the tangible output) -->
    <div class="doc-shot reveal" role="img" aria-label={t('workflow.doc.title')}>
      <div class="doc-window">
        <div class="doc-titlebar">
          <span class="doc-dots" aria-hidden="true"><i></i><i></i><i></i></span>
          <span class="doc-app">Google Docs</span>
          <span class="doc-ai-chip">
            <span class="doc-ai-dot" aria-hidden="true"></span>
            {t('workflow.doc.badge')}
          </span>
        </div>
        <div class="doc-body">
          <h3 class="doc-title">{t('workflow.doc.title')}</h3>
          <div class="doc-group">
            <span class="doc-label">{t('workflow.doc.decisions')}</span>
            <p class="doc-line"><span class="doc-bullet doc-bullet--check" aria-hidden="true"></span>{t('workflow.doc.d1')}</p>
            <p class="doc-line"><span class="doc-bullet doc-bullet--check" aria-hidden="true"></span>{t('workflow.doc.d2')}</p>
          </div>
          <div class="doc-group">
            <span class="doc-label">{t('workflow.doc.actions')}</span>
            <p class="doc-line"><span class="doc-bullet doc-bullet--box" aria-hidden="true"></span>{t('workflow.doc.a1')}</p>
            <p class="doc-line"><span class="doc-bullet doc-bullet--box" aria-hidden="true"></span>{t('workflow.doc.a2')}</p>
          </div>
        </div>
      </div>
      <div class="doc-glow" aria-hidden="true"></div>
    </div>

    <div class="workflow-cta reveal">
      <a href={localizePath('/aria', lang)} class="workflow-link">
        {t('spotlight.cta')}
        <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M3 8h10M9 4l4 4-4 4"/></svg>
      </a>
    </div>

  </div>
</section>

<style>
  .exec-workflow {
    padding-block: var(--space-128);
    background: linear-gradient(180deg, var(--color-surface) 0%, var(--color-surface-muted) 100%);
    border-top: var(--border-light);
  }

  .workflow-head {
    text-align: center;
    max-width: 640px;
    margin-inline: auto;
    margin-block-end: var(--space-64);
  }
  .workflow-eyebrow { display: block; color: var(--color-accent); margin-block-end: var(--space-16); }
  .workflow-sub {
    margin-block-start: var(--space-16);
    color: var(--color-text-secondary);
    font-size: 1.0625rem;
    line-height: 1.6;
  }

  /* ── Flow ───────────────────────────────────────── */
  .flow {
    list-style: none;
    padding: 0;
    margin: 0 auto var(--space-80);
    display: flex;
    flex-direction: column;
    align-items: stretch;
    gap: var(--space-12);
    max-width: 420px;
  }

  .flow-step {
    position: relative;
    display: grid;
    grid-template-columns: auto 1fr;
    grid-template-rows: auto auto;
    column-gap: var(--space-16);
    align-items: center;
    padding: var(--space-20, 20px) var(--space-24);
    background: var(--color-surface);
    border: var(--border-thin);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-xs);
    transition: transform var(--motion-normal), box-shadow var(--motion-normal), border-color var(--motion-fast);
  }
  .flow-step:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-md);
    border-color: var(--color-border-accent);
  }

  .flow-num {
    grid-row: 1 / span 2;
    display: none;
    width: 24px; height: 24px;
    align-items: center; justify-content: center;
    border-radius: var(--radius-full);
    background: var(--color-accent-light);
    color: var(--color-accent);
    font-size: var(--text-label);
    font-weight: var(--weight-bold);
  }
  .flow-icon {
    grid-row: 1 / span 2;
    display: inline-flex;
    align-items: center; justify-content: center;
    width: 44px; height: 44px;
    border-radius: var(--radius-medium);
    background: var(--color-accent-light);
    color: var(--color-accent);
  }
  .flow-icon svg { width: 22px; height: 22px; }
  .flow-title { font-size: var(--text-body-sm); font-weight: var(--weight-semibold); color: var(--color-primary); }
  .flow-desc  { font-size: var(--text-caption); line-height: 1.5; color: var(--color-text-secondary); }

  .flow-arrow {
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-muted);
    transform: rotate(90deg);
  }
  .flow-arrow svg { width: 20px; height: 20px; }

  /* Desktop: horizontal row of steps */
  @media (min-width: 900px) {
    .flow {
      flex-direction: row;
      align-items: stretch;
      justify-content: center;
      max-width: 100%;
      gap: var(--space-8);
    }
    .flow-step {
      flex: 1 1 0;
      grid-template-columns: 1fr;
      grid-template-rows: auto auto auto;
      justify-items: center;
      text-align: center;
      row-gap: var(--space-8);
      padding: var(--space-24) var(--space-16);
      min-width: 0;
    }
    .flow-num {
      grid-row: auto;
      display: inline-flex;
      position: absolute;
      top: var(--space-12);
      right: var(--space-12);
    }
    .flow-icon { grid-row: auto; }
    .flow-arrow { transform: none; flex: 0 0 auto; }
  }

  /* ── Doc screenshot ─────────────────────────────── */
  .doc-shot {
    position: relative;
    max-width: 640px;
    margin: 0 auto;
  }
  .doc-glow {
    position: absolute;
    inset: 10% 0 auto;
    height: 60%;
    background: var(--color-accent-glow);
    filter: blur(70px);
    opacity: 0.5;
    z-index: 0;
    pointer-events: none;
  }
  .doc-window {
    position: relative;
    z-index: 1;
    border: var(--border-thin);
    border-radius: var(--radius-2xl);
    background: var(--color-surface);
    box-shadow: var(--shadow-xl);
    overflow: hidden;
  }
  .doc-titlebar {
    display: flex;
    align-items: center;
    gap: var(--space-12);
    padding: var(--space-12) var(--space-16);
    border-bottom: var(--border-light);
    background: var(--color-surface-muted);
  }
  .doc-dots { display: inline-flex; gap: 5px; }
  .doc-dots i { width: 9px; height: 9px; border-radius: 50%; background: var(--color-border); display: block; }
  .doc-app { font-size: var(--text-caption); font-weight: var(--weight-medium); color: var(--color-text-secondary); }
  .doc-ai-chip {
    margin-inline-start: auto;
    display: inline-flex;
    align-items: center;
    gap: var(--space-8);
    padding: var(--space-4) var(--space-12);
    border-radius: var(--radius-full);
    background: var(--color-accent-light);
    color: var(--color-accent);
    font-size: var(--text-label);
    font-weight: var(--weight-semibold);
  }
  .doc-ai-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--color-accent); }

  .doc-body { padding: var(--space-32); display: flex; flex-direction: column; gap: var(--space-24); }
  .doc-title { font-size: var(--text-card); font-weight: var(--weight-bold); color: var(--color-primary); margin: 0; }
  .doc-group { display: flex; flex-direction: column; gap: var(--space-8); }
  .doc-label {
    font-size: var(--text-label);
    font-weight: var(--weight-semibold);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-muted);
    margin-block-end: var(--space-4);
  }
  .doc-line {
    display: flex;
    align-items: flex-start;
    gap: var(--space-12);
    font-size: var(--text-body-sm);
    color: var(--color-text-primary);
    line-height: 1.5;
  }
  .doc-bullet { flex-shrink: 0; margin-top: 3px; width: 15px; height: 15px; }
  .doc-bullet--check {
    border-radius: 50%;
    background: var(--color-success);
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 12 12' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M3 6l2 2 4-4.5' stroke='white' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E");
    background-size: 12px; background-repeat: no-repeat; background-position: center;
  }
  .doc-bullet--box {
    border-radius: 4px;
    border: 1.5px solid var(--color-border-accent);
  }

  /* ── CTA ────────────────────────────────────────── */
  .workflow-cta { text-align: center; margin-block-start: var(--space-48); }
  .workflow-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-8);
    font-weight: var(--weight-semibold);
    font-size: var(--text-body-sm);
    color: var(--color-accent);
    text-decoration: none;
  }
  .workflow-link svg { width: 16px; height: 16px; transition: transform var(--motion-fast); }
  .workflow-link:hover svg { transform: translateX(3px); }
</style>
