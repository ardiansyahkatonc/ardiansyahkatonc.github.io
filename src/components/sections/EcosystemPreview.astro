---
import { getLangFromUrl, useTranslations, localizePath } from '../../i18n';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const products = [
  { id: 'aria', name: 'ARIA', statusVariant: 'primary', href: '/aria', active: true },
  { id: 'kcc', name: 'KCC', statusVariant: 'neutral', href: null, active: false },
  { id: 'future', name: 'Future Products', statusVariant: 'neutral', href: '/projects', active: false },
] as const;
---

<section class="section section-xl ecosystem-section" aria-labelledby="ecosystem-heading">
  <div class="container-xl">

    <div class="ecosystem-header reveal">
      <span class="label text-muted">{t('ecosystem.label')}</span>
      <h2 id="ecosystem-heading" class="section-title">{t('ecosystem.title')}</h2>
    </div>

    <div class="ecosystem-roadmap">
      {products.map((product, index) => (
        <div class="roadmap-item reveal" id={`product-${product.id}`}>
          {index < products.length - 1 && (
            <div class="roadmap-connector">
              <div class="connector-line"></div>
              <div class="connector-arrow">↓</div>
            </div>
          )}

          <div class={`roadmap-card ${product.active ? 'is-active' : ''}`}>
            <div class="roadmap-card-header">
              <div class="roadmap-badge-group">
                <span class={`roadmap-badge badge-${product.statusVariant}`}>{t(`ecosystem.${product.id}.status` as any)}</span>
              </div>
              <h3 class={`card-title product-name ${!product.active ? 'text-muted' : ''}`}>{product.name}</h3>
            </div>

            <div class="roadmap-desc body-sm">{t(`ecosystem.${product.id}.desc` as any)}</div>

            {product.href ? (
              <a href={localizePath(product.href, lang)} class={`roadmap-cta ${product.active ? 'cta-primary' : 'cta-secondary'}`}>
                {t(`ecosystem.${product.id}.cta` as any)}
                <span aria-hidden="true" class="cta-arr">→</span>
              </a>
            ) : (
              <span class="roadmap-cta cta-disabled">{t(`ecosystem.${product.id}.cta` as any)}</span>
            )}
          </div>
        </div>
      ))}
    </div>

  </div>
</section>

<style>
  .ecosystem-section {
    background-color: var(--color-surface);
    border-top: var(--border-light);
  }

  .ecosystem-header {
    margin-block-end: var(--space-80);
    text-align: center;
  }

  .text-muted { color: var(--color-text-secondary); }

  .ecosystem-roadmap {
    display: flex;
    flex-direction: column;
    align-items: center;
    max-width: 500px;
    margin: 0 auto;
  }

  .roadmap-item {
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .roadmap-card {
    width: 100%;
    background: var(--color-background);
    border: var(--border-thin);
    border-radius: var(--radius-2xl);
    padding: var(--space-32);
    transition: box-shadow var(--motion-normal), transform var(--motion-normal);
  }

  .roadmap-card.is-active {
    background: var(--color-surface);
    border-color: var(--color-border-accent);
    box-shadow: 0 0 0 1px var(--color-border-accent), var(--shadow-sm);
  }

  .roadmap-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
  }

  .roadmap-card-header { margin-block-end: var(--space-16); }
  .roadmap-badge-group { margin-block-end: var(--space-12); }

  .roadmap-badge {
    display: inline-block;
    font-size: var(--text-label);
    font-weight: var(--weight-semibold);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: var(--space-4) var(--space-12);
    border-radius: var(--radius-full);
  }

  .badge-primary {
    background: rgba(37, 99, 235, 0.1);
    color: var(--color-accent);
  }

  .badge-neutral {
    background: rgba(15, 23, 42, 0.05);
    color: var(--color-text-secondary);
  }

  .product-name { margin: 0; }
  .roadmap-desc { margin-block-end: var(--space-24); color: var(--color-text-secondary); }

  .roadmap-cta {
    display: inline-flex;
    align-items: center;
    gap: var(--space-4);
    font-weight: var(--weight-medium);
    font-size: var(--text-caption);
    text-decoration: none;
    transition: all var(--motion-fast);
  }

  .cta-primary { color: var(--color-accent); }
  .cta-primary:hover { color: var(--color-accent-hover); }
  .cta-primary:hover .cta-arr { transform: translateX(3px); }

  .cta-secondary { color: var(--color-text-secondary); }
  .cta-secondary:hover { color: var(--color-primary); }

  .cta-disabled { color: var(--color-muted); cursor: default; }

  .cta-arr { transition: transform var(--motion-fast); }

  .roadmap-connector {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding-block: var(--space-16);
    color: var(--color-border);
  }

  .connector-line {
    width: 2px;
    height: var(--space-32);
    background: var(--color-border);
  }

  .connector-arrow { font-size: var(--text-caption); }
</style>
