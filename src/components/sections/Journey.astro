---
import { journey } from '../../config/journey';
---
<section class="section section-content journey-section" aria-labelledby="journey-heading">
  <div class="container-xl">
    <div class="journey-header">
      <span class="section-label label">Timeline</span>
      <h2 id="journey-heading" class="h2">Journey</h2>
    </div>
    <div class="timeline">
      {journey.map(group => (
        <ol class="timeline-list" aria-label={`${group.year} milestones`}>
          {group.milestones.map((milestone, index) => (
            <li class="timeline-item">
              <div class="timeline-indicator" aria-hidden="true">
                <span class="timeline-dot"></span>
                {index < group.milestones.length - 1 && (
                  <span class="timeline-line"></span>
                )}
              </div>
              <div class="timeline-content">
                <h3 class="milestone-title title">{milestone.title}</h3>
                <p class="milestone-desc body text-muted">{milestone.description}</p>
              </div>
            </li>
          ))}
        </ol>
      ))}
    </div>
  </div>
</section>

<style>
  .journey-section {
    background-color: var(--color-surface);
    border-top: var(--border-light);
  }

  .journey-header {
    margin-block-end: var(--space-64);
  }

  .section-label {
    display: block;
    color: var(--color-muted);
    margin-block-end: var(--space-16);
  }

  .timeline {
    max-width: 40rem;
  }

  .timeline-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .timeline-item {
    display: flex;
    gap: var(--space-24);
  }

  .timeline-indicator {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding-top: var(--space-8);
    width: var(--space-16);
    flex-shrink: 0;
  }

  .timeline-dot {
    width: 7px;
    height: 7px;
    border-radius: var(--radius-full);
    background-color: var(--color-text-primary);
    flex-shrink: 0;
  }

  .timeline-line {
    width: 1px;
    flex-grow: 1;
    background-color: var(--color-border);
    margin-block: var(--space-8);
    min-height: var(--space-48);
  }

  .timeline-content {
    padding-bottom: var(--space-48);
  }

  .milestone-title {
    color: var(--color-text-primary);
    margin-block: 0 var(--space-8);
  }

  .milestone-desc {
    color: var(--color-text-secondary);
    margin-block: 0;
    max-width: 45ch;
  }

  .text-muted { color: var(--color-text-secondary); }
</style>
