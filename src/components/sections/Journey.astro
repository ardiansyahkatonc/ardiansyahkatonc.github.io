---
import { getLangFromUrl, useTranslations } from '../../i18n';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const milestones = [
  { key: 'journey.vibe.desc', year: '2024', title: 'Google AI Vibe Coding', status: 'completed' },
  { key: 'journey.kcc.desc', year: '2024', title: 'KATON COMMAND CENTER', status: 'completed' },
  { key: 'journey.arch.desc', year: '2025', title: 'Knowledge Architecture', status: 'completed' },
  { key: 'journey.mvp.desc', year: '2026', title: 'ARIA MVP', status: 'completed' },
  { key: 'journey.launch.desc', year: 'Jul 2026', title: 'ARIA Launch', status: 'active' },
  { key: 'journey.enterprise.desc', year: '2027', title: 'Enterprise Edition', status: 'upcoming' },
  { key: 'journey.ecosystem.desc', year: '2028', title: 'AI Native Ecosystem', status: 'upcoming' },
] as const;
---

<section class="section section-xl journey-section" aria-labelledby="journey-heading">
  <div class="container-xl">

    <div class="journey-header reveal">
      <span class="label text-muted">{t('journey.label')}</span>
      <h2 id="journey-heading" class="section-title">{t('journey.title')}</h2>
    </div>

    <!-- Horizontal Desktop Timeline -->
    <div class="timeline-scroll-wrapper">
      <div class="timeline-track">
        {milestones.map((milestone, index) => (
          <div class={`timeline-node ${milestone.status}`} id={`milestone-${index}`}>
            <div class="node-marker">
              <div class="node-dot"></div>
              {index < milestones.length - 1 && <div class="node-line"></div>}
            </div>
            <div class="node-content">
              <span class="node-year label text-muted">{milestone.year}</span>
              <h3 class="card-title node-title">{milestone.title}</h3>
              <p class="body-sm text-muted">{t(milestone.key as any)}</p>
            </div>
          </div>
        ))}
      </div>
    </div>

  </div>
</section>

<style>
  .journey-section {
    background-color: var(--color-surface);
    border-top: var(--border-light);
    overflow: hidden; /* clip horizontal scroll from bleeding out */
  }

  .journey-header {
    margin-block-end: var(--space-64);
  }

  .text-muted { color: var(--color-text-secondary); }

  /* -----------------------------------------------------------------------
     Mobile: Vertical Timeline
     ----------------------------------------------------------------------- */
  .timeline-scroll-wrapper {
    width: 100%;
  }

  .timeline-track {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .timeline-node {
    display: flex;
    gap: var(--space-24);
    position: relative;
  }

  .node-marker {
    display: flex;
    flex-direction: column;
    align-items: center;
    flex-shrink: 0;
    width: 24px;
    padding-top: var(--space-4);
  }

  .node-dot {
    width: 14px;
    height: 14px;
    border-radius: var(--radius-full);
    background-color: var(--color-border);
    border: 2px solid var(--color-surface);
    box-shadow: 0 0 0 2px var(--color-border);
    z-index: 1;
    flex-shrink: 0;
  }

  .timeline-node.completed .node-dot {
    background-color: var(--color-primary);
    box-shadow: 0 0 0 2px rgba(15, 23, 42, 0.1);
  }

  .timeline-node.active .node-dot {
    background-color: var(--color-accent);
    box-shadow: 0 0 0 4px rgba(37, 99, 235, 0.2);
    width: 16px;
    height: 16px;
  }

  .node-line {
    width: 2px;
    flex-grow: 1;
    background: var(--color-border);
    min-height: 40px;
    margin-block: var(--space-8);
  }

  .node-content {
    padding-bottom: var(--space-48);
  }

  .node-year {
    display: block;
    margin-block-end: var(--space-8);
  }

  .node-title {
    margin-block-start: 0;
    margin-block-end: var(--space-12);
  }

  .timeline-node.upcoming .node-title,
  .timeline-node.upcoming .bilingual-id,
  .timeline-node.upcoming .bilingual-en {
    color: var(--color-muted);
  }

  .timeline-node.active .node-title {
    color: var(--color-accent);
  }

  /* -----------------------------------------------------------------------
     Desktop: Horizontal Timeline
     ----------------------------------------------------------------------- */
  @media (min-width: 1024px) {
    .timeline-scroll-wrapper {
      overflow-x: auto;
      padding-block-end: var(--space-32);
      scrollbar-width: thin;
      scrollbar-color: var(--color-border) transparent;
    }

    .timeline-scroll-wrapper::-webkit-scrollbar {
      height: 4px;
    }

    .timeline-scroll-wrapper::-webkit-scrollbar-track {
      background: transparent;
    }

    .timeline-scroll-wrapper::-webkit-scrollbar-thumb {
      background: var(--color-border);
      border-radius: var(--radius-full);
    }

    .timeline-track {
      flex-direction: row;
      align-items: flex-start;
      gap: 0;
      min-width: max-content;
      padding-inline: var(--space-32);
    }

    .timeline-node {
      flex-direction: column;
      gap: var(--space-16);
      width: 240px;
      flex-shrink: 0;
    }

    .node-marker {
      flex-direction: row;
      align-items: center;
      width: 100%;
      padding-top: 0;
    }

    .node-line {
      width: auto;
      flex-grow: 1;
      height: 2px;
      min-height: 0;
      margin-block: 0;
      margin-inline: var(--space-8);
    }

    .node-content {
      padding-bottom: 0;
      padding-inline-end: var(--space-24);
    }
  }

  .reveal {
    opacity: 0;
    transform: translateY(30px);
    transition: all 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .reveal.active {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script>
  if (typeof window !== 'undefined') {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) entry.target.classList.add('active');
      });
    }, { threshold: 0.05 });
    document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
  }
</script>
