---
import { getLangFromUrl, useTranslations } from '../../i18n';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const stories = ['p1', 'p2', 'p3'] as const;
---
<section class="section section-content problem-section" aria-labelledby="problem-heading">
  <div class="container-lg">
    <div class="section-header text-center reveal">
      <h2 id="problem-heading" class="section-title">{t('problem.heading')}</h2>
    </div>

    <div class="storytelling-flow">
      {stories.map((s, index) => (
        <div class="story-card reveal" id={`story-${s}`}>
          <div class="story-indicator">
            <div class="story-dot"></div>
            {index < stories.length - 1 && <div class="story-line"></div>}
          </div>
          <div class="story-content">
            <div class="mb-8 label text-accent">{t(`problem.${s}.label` as any)}</div>
            <h3 class="card-title mb-16">{t(`problem.${s}.title` as any)}</h3>
            <p class="body text-muted">{t(`problem.${s}.desc` as any)}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .problem-section {
    background-color: var(--color-surface);
    border-top: var(--border-light);
  }
  
  .section-header {
    margin-block-end: var(--space-80);
  }

  .text-center { text-align: center; }
  .text-accent { color: var(--color-accent); }
  .text-muted { color: var(--color-text-secondary); }
  .mb-8 { margin-block-end: var(--space-8); }
  .mb-16 { margin-block-end: var(--space-16); }

  .storytelling-flow {
    display: flex;
    flex-direction: column;
    max-width: 800px;
    margin: 0 auto;
  }

  .story-card {
    display: flex;
    gap: var(--space-32);
  }

  .story-indicator {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 24px;
    flex-shrink: 0;
    padding-top: var(--space-12);
  }

  .story-dot {
    width: 12px;
    height: 12px;
    border-radius: var(--radius-full);
    background-color: var(--color-primary);
    border: 2px solid var(--color-surface);
    box-shadow: 0 0 0 2px rgba(15, 23, 42, 0.1);
    flex-shrink: 0;
  }

  .story-line {
    width: 2px;
    flex-grow: 1;
    background-color: var(--color-border);
    margin-block: var(--space-8);
    min-height: var(--space-64);
  }

  .story-content {
    padding-bottom: var(--space-64);
    background: transparent;
  }
</style>
