---
const problems = [
  {
    id: 'scattered-knowledge',
    title: 'Scattered Institutional Knowledge',
    description: 'Critical information lives in emails, chat threads, and personal drives — with no reliable way to find or reuse it.',
  },
  {
    id: 'repetitive-admin',
    title: 'Repetitive Administrative Work',
    description: 'Staff spend significant time on routine tasks that could be structured, templated, or automated.',
  },
  {
    id: 'meeting-documentation',
    title: 'Meeting Documentation Gaps',
    description: 'Decisions made in meetings rarely produce structured records. Follow-through depends on individual memory.',
  },
  {
    id: 'fragmented-information',
    title: 'Fragmented Information Systems',
    description: 'Data exists across multiple platforms with no unified view, making coordination and reporting slow and error-prone.',
  },
];
---
<section class="section section-content problem-section" aria-labelledby="problem-heading">
  <div class="container-xl">
    <div class="problem-grid-layout">
      
      <div class="problem-header">
        <span class="section-label label">The Challenge</span>
        <h2 id="problem-heading" class="problem-title h2">
          Government organizations manage complexity with limited tools.
        </h2>
        <p class="body-lg text-muted">
          The public sector runs on critical information, but the current systems create friction instead of flow.
        </p>
      </div>
      
      <div class="problem-list">
        {problems.map((problem, index) => (
          <div class="problem-item" id={`problem-${problem.id}`}>
            <div class="problem-number">0{index + 1}</div>
            <div class="problem-content">
              <h3 class="problem-item-title h4">{problem.title}</h3>
              <p class="problem-item-desc body text-muted">{problem.description}</p>
            </div>
          </div>
        ))}
      </div>
      
    </div>
  </div>
</section>

<style>
  .problem-section {
    background-color: var(--color-surface);
    border-top: var(--border-light);
  }

  .problem-grid-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-64);
  }
  
  .section-label {
    color: var(--color-muted);
    margin-block-end: var(--space-16);
    display: block;
  }

  .problem-title {
    margin-block-start: 0;
    margin-block-end: var(--space-24);
    max-width: 20ch;
  }

  .text-muted {
    color: var(--color-text-secondary);
  }

  .problem-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-48);
  }

  .problem-item {
    display: flex;
    gap: var(--space-24);
    align-items: flex-start;
  }

  .problem-number {
    font-family: var(--font-mono);
    font-size: var(--text-caption);
    font-weight: var(--weight-bold);
    color: var(--color-muted);
    padding-top: var(--space-8);
    border-top: 2px solid var(--color-border);
    min-width: 2rem;
  }

  .problem-item-title {
    margin-block: 0 var(--space-8);
    color: var(--color-text-primary);
  }

  .problem-item-desc {
    margin-block: 0;
    max-width: 45ch;
  }

  @media (min-width: 1024px) {
    .problem-grid-layout {
      grid-template-columns: 5fr 7fr;
      gap: var(--space-128);
    }
    
    .problem-header {
      position: sticky;
      top: var(--space-128);
      align-self: flex-start;
    }
  }
</style>
