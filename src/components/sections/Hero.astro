---
---
<section class="section section-lg hero-section" aria-labelledby="hero-heading">
  <div class="container-xl hero-inner">
    <div class="hero-content">
      <h1 id="hero-heading" class="hero-headline">
        Building AI-Native Solutions<br class="hero-break" /> for Public Sector Indonesia
      </h1>
      <p class="hero-subheadline">
        kat.on develops practical AI products that simplify government workflows through automation, knowledge systems, and human-centered AI.
      </p>
      <div class="hero-actions">
        <a href="/aria" class="cta-primary">Explore ARIA</a>
        <a href="/projects" class="cta-secondary">View Projects</a>
      </div>
    </div>
  </div>
</section>

<style>
  .hero-section {
    min-height: 72vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .hero-inner {
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .hero-content {
    max-width: 52rem;
  }

  .hero-headline {
    font-size: var(--text-h1);
    font-weight: var(--weight-bold);
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--color-text-primary);
    margin-block-start: 0;
    margin-block-end: var(--space-24);
  }

  .hero-break {
    display: none;
  }

  .hero-subheadline {
    font-size: var(--text-body-lg);
    line-height: 1.6;
    color: var(--color-text-secondary);
    max-width: 60ch;
    margin-block-start: 0;
    margin-block-end: var(--space-32);
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-16);
  }

  /* CTA anchor styles — styled via ECF tokens, not Button component (buttons are for actions, anchors for navigation) */
  .cta-primary,
  .cta-secondary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: var(--space-48);
    padding-inline: var(--space-24);
    font-family: var(--font-primary);
    font-size: var(--text-body);
    font-weight: var(--weight-medium);
    text-decoration: none;
    border-radius: var(--radius-medium);
    transition: all var(--motion-fast);
  }

  .cta-primary:focus-visible,
  .cta-secondary:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  .cta-primary {
    background-color: var(--color-primary);
    color: var(--color-surface);
    border: 2px solid var(--color-primary);
  }

  .cta-primary:hover {
    opacity: 0.88;
  }

  .cta-secondary {
    background-color: transparent;
    color: var(--color-text-primary);
    border: var(--border-thin);
  }

  .cta-secondary:hover {
    background-color: var(--color-secondary);
    border-color: var(--color-text-secondary);
  }

  @media (min-width: 768px) {
    .hero-headline {
      font-size: var(--text-display);
    }

    .hero-break {
      display: inline;
    }
  }
</style>
