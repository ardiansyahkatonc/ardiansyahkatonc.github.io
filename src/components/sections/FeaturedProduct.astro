---
import { products } from '../../config/products';

const featuredProduct = products.find(p => p.featured) || products.find(p => p.id === 'aria');
---
<section class="section featured-section">
  <div class="container">
    <h2 class="section-label text-sm">Featured Product</h2>
    {featuredProduct && (
      <div class="featured-card">
        <div class="featured-header">
          <h3 class="featured-name">{featuredProduct.title}</h3>
          <span class="status-badge">{featuredProduct.featuredStatus || featuredProduct.status}</span>
        </div>
        <p class="featured-tagline text-sm">{featuredProduct.description}</p>
        <p class="featured-desc">{featuredProduct.featuredDescription}</p>
        <a href="/aria" class="btn-link">Learn More &rarr;</a>
      </div>
    )}
  </div>
</section>

<style>
  .featured-section {
    border-top: 1px solid var(--color-border);
  }

  .section-label {
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: var(--space-8);
  }

  .featured-card {
    border: 1px solid var(--color-border);
    padding: var(--space-6);
    border-radius: 4px;
    background: var(--color-secondary);
  }

  .featured-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--space-2);
  }

  .featured-name {
    margin: 0;
    font-size: var(--text-2xl);
    letter-spacing: -0.01em;
  }

  .status-badge {
    font-size: var(--text-xs);
    padding: var(--space-1) var(--space-2);
    border: 1px solid var(--color-border);
    border-radius: 9999px;
    background: var(--color-background);
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .featured-tagline {
    color: var(--color-primary);
    margin-bottom: var(--space-4);
    font-weight: var(--font-weight-medium);
  }

  .featured-desc {
    color: var(--color-text-muted);
    margin-bottom: var(--space-6);
  }

  .btn-link {
    display: inline-flex;
    align-items: center;
    color: var(--color-primary);
    text-decoration: none;
    font-weight: var(--font-weight-medium);
  }

  .btn-link:hover, .btn-link:focus {
    text-decoration: underline;
  }
</style>
