---
import ARIADashboard from '../ui/mockup/ARIADashboard.astro';

const capabilities = [
  {
    icon: '◎',
    id: 'exec-briefing',
    title: 'Executive Briefing',
    descId: 'Ringkasan eksekutif harian otomatis dari semua aktivitas, rapat, dan keputusan penting.',
    descEn: 'Automated daily executive summaries from all activities, meetings, and key decisions.',
  },
  {
    icon: '◈',
    id: 'meeting-intel',
    title: 'Meeting Intelligence',
    descId: 'Mengubah percakapan menjadi notulen resmi, keputusan, dan tindak lanjut secara otomatis.',
    descEn: 'Automatically converts meetings into structured minutes, decisions, and follow-up actions.',
  },
  {
    icon: '▣',
    id: 'knowledge-mgmt',
    title: 'Knowledge Management',
    descId: 'Membangun basis pengetahuan institusional yang dinamis, dapat dicari, dan berkelanjutan.',
    descEn: 'Builds a dynamic institutional knowledge base that is searchable, contextual, and sustainable.',
  },
  {
    icon: '⬡',
    id: 'doc-auto',
    title: 'Document Automation',
    descId: 'Mempercepat pembuatan dokumen administrasi menggunakan konteks organisasi secara langsung.',
    descEn: 'Accelerates administrative document creation using your organization\'s context directly.',
  },
  {
    icon: '◇',
    id: 'decision-support',
    title: 'Decision Support',
    descId: 'Memberikan rekomendasi berbasis data dari memori institusional untuk mendukung pengambilan keputusan.',
    descEn: 'Provides data-driven recommendations from institutional memory to support decision-making.',
  },
  {
    icon: '◉',
    id: 'workspace',
    title: 'AI Workspace',
    descId: 'Antarmuka terpusat dan aman untuk semua tugas berbantuan AI—rapat, dokumen, dan pengetahuan.',
    descEn: 'A centralized, secure interface for all AI-assisted tasks — meetings, documents, and knowledge.',
  },
];
---

<section class="section section-xl aria-section" aria-labelledby="aria-heading">
  <div class="container-xl">

    <!-- Section Header -->
    <div class="aria-header reveal">
      <div class="aria-badge-row">
        <span class="aria-badge">
          <span data-lang-id>Produk Unggulan</span>
          <span data-lang-en style="display:none">Flagship Product</span>
        </span>
      </div>
      <h2 id="aria-heading" class="section-title aria-title">ARIA</h2>
      <div class="aria-subtitle-group">
        <p class="body-lg text-measure text-muted">
          <span data-lang-id>Asisten Eksekutif AI untuk Sektor Publik — mengelola rapat, dokumen, pengetahuan, dan keputusan organisasi Anda.</span>
          <span data-lang-en style="display:none">AI Executive Assistant for the Public Sector — managing your organization's meetings, documents, knowledge, and decisions.</span>
        </p>
      </div>
    </div>

    <!-- Mockup -->
    <div class="aria-mockup reveal animate-delay-1">
      <ARIADashboard />
    </div>

    <!-- Capabilities Grid -->
    <div class="capabilities-header reveal">
      <span class="label text-muted">
        <span data-lang-id>Kapabilitas Utama</span>
        <span data-lang-en style="display:none">Core Capabilities</span>
      </span>
    </div>
    <div class="grid-2 capabilities-grid">
      {capabilities.map((cap, idx) => (
        <div class={`capability-card reveal reveal-delay-${(idx % 2) + 1}`} id={cap.id}>
          <div class="capability-icon">{cap.icon}</div>
          <div class="capability-text">
            <h3 class="card-title capability-title">{cap.title}</h3>
            <p class="body-sm text-secondary">
              <span data-lang-id>{cap.descId}</span>
              <span data-lang-en style="display:none">{cap.descEn}</span>
            </p>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>

<style>
  .aria-section {
    background: var(--color-background);
    border-top: var(--border-light);
  }

  .aria-header { margin-block-end: var(--space-64); }
  .aria-badge-row { margin-block-end: var(--space-24); }

  .aria-badge {
    display: inline-flex;
    padding: var(--space-4) var(--space-12);
    border-radius: var(--radius-full);
    font-size: var(--text-label);
    font-weight: var(--weight-semibold);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    background: rgba(37, 99, 235, 0.1);
    color: var(--color-accent);
  }

  .aria-title {
    margin-block-start: 0;
    margin-block-end: var(--space-24);
  }

  .aria-subtitle-group { max-width: 60ch; }
  .text-muted { color: var(--color-text-secondary); }
  .text-secondary { color: var(--color-text-secondary); }
  
  .aria-mockup { margin-block-end: var(--space-96); }
  .capabilities-header { margin-block-end: var(--space-48); }

  .capabilities-grid {
    gap: var(--space-2);
    margin-block-end: var(--space-80);
  }

  .capability-card {
    display: flex;
    gap: var(--space-24);
    padding: var(--space-32);
    border-radius: var(--radius-xl);
    border: var(--border-light);
    background-color: var(--color-surface);
    transition: box-shadow var(--motion-fast), transform var(--motion-fast);
  }

  .capability-card:hover {
    box-shadow: var(--shadow-md);
    transform: translateY(-4px);
  }

  .capability-icon {
    font-size: 2rem;
    line-height: 1;
    color: var(--color-accent);
    flex-shrink: 0;
    margin-top: var(--space-4);
  }

  .capability-title {
    margin-block-start: 0;
    margin-block-end: var(--space-12);
  }

  @media (min-width: 768px) {
    .capabilities-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (min-width: 1024px) {
    .capabilities-grid { grid-template-columns: repeat(3, 1fr); }
  }
</style>
