---
import { products } from '../../config/products';

const aria = products.find(p => p.id === 'aria');
---
<section class="section section-content aria-section" aria-labelledby="aria-heading">
  <div class="container-xl">
    {aria && (
      <div class="aria-card">
        <div class="aria-header">
          <span class="section-label label">Flagship Product</span>
          <span class="aria-badge">{aria.featuredStatus}</span>
        </div>
        <h2 id="aria-heading" class="aria-title display">{aria.title}</h2>
        <p class="aria-subtitle title text-muted">{aria.description}</p>
        <p class="aria-desc body-lg text-muted">{aria.featuredDescription}</p>
        <a href="/aria" class="aria-cta">
          Learn More
          <svg class="cta-arrow" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
    )}
  </div>
</section>

<style>
  .aria-section {
    background-color: var(--color-surface);
    border-top: var(--border-light);
  }

  .aria-card {
    border: var(--border-light);
    border-radius: var(--radius-2xl);
    padding: var(--space-64);
    background-color: var(--color-surface-muted);
    max-width: 56rem;
  }

  .aria-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-block-end: var(--space-32);
    flex-wrap: wrap;
    gap: var(--space-16);
  }

  .section-label {
    color: var(--color-muted);
  }

  .aria-badge {
    display: inline-flex;
    align-items: center;
    padding: var(--space-4) var(--space-16);
    border-radius: var(--radius-full);
    border: var(--border-thin);
    font-size: var(--text-caption);
    font-weight: var(--weight-semibold);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-text-secondary);
    background-color: var(--color-surface);
  }

  .aria-title {
    margin-block: 0 var(--space-16);
    color: var(--color-text-primary);
  }

  .aria-subtitle {
    color: var(--color-text-secondary);
    margin-block: 0 var(--space-24);
  }

  .aria-desc {
    color: var(--color-text-secondary);
    max-width: 55ch;
    margin-block: 0 var(--space-48);
  }

  .text-muted { color: var(--color-text-secondary); }

  .aria-cta {
    display: inline-flex;
    align-items: center;
    gap: var(--space-8);
    font-size: var(--text-body);
    font-weight: var(--weight-semibold);
    color: var(--color-text-primary);
    text-decoration: none;
    transition: gap var(--motion-fast);
  }

  .cta-arrow {
    transition: transform var(--motion-fast);
  }

  .aria-cta:hover {
    gap: var(--space-12);
  }

  .aria-cta:hover .cta-arrow {
    transform: translateX(3px);
  }

  .aria-cta:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 3px;
    border-radius: var(--radius-small);
  }
</style>
