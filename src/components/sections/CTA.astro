---
import { social } from '../../config/social';
import { getLangFromUrl, useTranslations } from '../../i18n';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section class="section cta-section" aria-labelledby="cta-heading">
  <div class="container-md">
    <div class="cta-inner reveal">
      <h2 id="cta-heading" class="section-title cta-title">{t('homecta.title')}</h2>
      <div class="cta-subtitle">
        <p class="text-muted">{t('homecta.sub')}</p>
      </div>

      <div class="cta-buttons">
        <a href={social.github} class="cta-btn" target="_blank" rel="noopener noreferrer" id="cta-github">
          <span class="cta-btn-icon">
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
            </svg>
          </span>
          {t('homecta.github')}
        </a>
        <a href={social.linkedin} class="cta-btn" target="_blank" rel="noopener noreferrer" id="cta-linkedin">
          <span class="cta-btn-icon">
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </span>
          {t('homecta.linkedin')}
        </a>
        <a href={social.email} class="cta-btn cta-btn-primary" id="cta-email">
          <span class="cta-btn-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
              <polyline points="22,6 12,13 2,6"/>
            </svg>
          </span>
          {t('homecta.email')}
        </a>
      </div>
    </div>
  </div>
</section>

<script>
  if (typeof window !== 'undefined') {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) entry.target.classList.add('active');
      });
    }, { threshold: 0.1 });
    document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
  }
</script>

<style>
  .cta-section {
    background-color: var(--color-background);
    border-top: var(--border-light);
  }

  .cta-inner {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .cta-title {
    margin-block-start: 0;
    margin-block-end: var(--space-24);
  }

  .cta-subtitle {
    max-width: 55ch;
    margin-block-end: var(--space-64);
    text-align: center;
  }

  .text-muted { color: var(--color-text-secondary); }

  .cta-buttons {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-16);
  }

  .cta-btn {
    display: inline-flex;
    align-items: center;
    gap: var(--space-12);
    height: var(--space-48);
    padding-inline: var(--space-24);
    border-radius: var(--radius-full);
    font-weight: var(--weight-medium);
    font-size: var(--text-caption);
    text-decoration: none;
    border: var(--border-thin);
    color: var(--color-text-primary);
    background-color: var(--color-surface);
    transition: all var(--motion-fast);
  }

  .cta-btn:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
    border-color: var(--color-border);
  }

  .cta-btn-primary {
    background-color: var(--color-primary);
    color: var(--color-surface);
    border-color: var(--color-primary);
  }

  .cta-btn-primary:hover {
    background-color: var(--color-accent);
    border-color: var(--color-accent);
  }

  .cta-btn-icon {
    display: inline-flex;
    align-items: center;
    width: 18px;
    height: 18px;
  }

  .cta-btn-icon svg {
    width: 100%;
    height: 100%;
  }

  .reveal {
    opacity: 0;
    transform: translateY(30px);
    transition: all 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .reveal.active {
    opacity: 1;
    transform: translateY(0);
  }
</style>
