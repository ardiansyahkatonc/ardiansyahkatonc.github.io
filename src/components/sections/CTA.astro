---
import { social } from '../../config/social';
---
<section class="section section-content cta-section" aria-labelledby="cta-heading">
  <div class="container-xl cta-inner">
    <div class="cta-content">
      <span class="section-label label">Collaboration</span>
      <h2 id="cta-heading" class="h2 cta-title">Let's build something meaningful.</h2>
      <p class="body-lg cta-invitation">We invite partnerships to accelerate public service delivery in Indonesia's public sector.</p>
    </div>
    <ul class="cta-links" aria-label="Contact & Social Links">
      <li><a href={social.github} class="cta-link" target="_blank" rel="noopener noreferrer">GitHub</a></li>
      <li><a href={social.linkedin} class="cta-link" target="_blank" rel="noopener noreferrer">LinkedIn</a></li>
      <li><a href={social.instagram} class="cta-link" target="_blank" rel="noopener noreferrer">Instagram</a></li>
      <li><a href={social.email} class="cta-link">Email</a></li>
    </ul>
  </div>
</section>

<style>
  .cta-section {
    background-color: var(--color-primary);
    border-top: none;
  }

  .cta-inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-64);
  }

  .section-label {
    display: block;
    color: rgba(255, 255, 255, 0.4);
    margin-block-end: var(--space-24);
  }

  .cta-title {
    color: var(--color-surface);
    margin-block: 0 var(--space-16);
    max-width: 20ch;
  }

  .cta-invitation {
    color: rgba(255, 255, 255, 0.6);
    margin-block: 0;
    max-width: 45ch;
  }

  .cta-links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    justify-content: flex-end;
  }

  .cta-link {
    font-size: var(--text-h3);
    font-weight: var(--weight-bold);
    letter-spacing: -0.02em;
    color: rgba(255, 255, 255, 0.35);
    text-decoration: none;
    transition: color var(--motion-fast);
    display: block;
    line-height: 1.2;
  }

  .cta-link:hover {
    color: var(--color-surface);
  }

  .cta-link:focus-visible {
    outline: 2px solid rgba(255, 255, 255, 0.5);
    outline-offset: 4px;
    border-radius: var(--radius-small);
    color: var(--color-surface);
  }

  @media (min-width: 768px) {
    .cta-inner {
      flex-direction: row;
      justify-content: space-between;
      align-items: flex-end;
    }

    .cta-links {
      text-align: right;
    }
  }
</style>
