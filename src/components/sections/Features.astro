---
const features = [
  {
    id: 'meeting-intelligence',
    title: 'Meeting Intelligence',
    description: 'Automatically captures, structures, and distributes meeting outcomes — decisions, action items, and key points — without manual effort.',
    icon: '◎',
  },
  {
    id: 'knowledge-management',
    title: 'Knowledge Management',
    description: 'Organizes institutional knowledge into searchable, accessible formats so information is available when and where it is needed.',
    icon: '▣',
  },
  {
    id: 'document-automation',
    title: 'Document Automation',
    description: 'Generates, processes, and formats documents using AI-assisted workflows, reducing turnaround time for routine outputs.',
    icon: '◈',
  },
  {
    id: 'ai-workspace',
    title: 'AI Workspace',
    description: 'A unified interface for AI-assisted tasks across your organization — consistent, context-aware, and accessible to every team member.',
    icon: '⬡',
  },
];
---
<section class="section section-content features-section" aria-labelledby="features-heading">
  <div class="container-xl">
    <div class="features-header">
      <span class="section-label label">Key Features</span>
      <h2 id="features-heading" class="features-title h2">What ARIA does</h2>
    </div>
    <div class="features-grid">
      {features.map((feature) => (
        <div class="feature-card" id={`feature-${feature.id}`}>
          <span class="feature-icon" aria-hidden="true">{feature.icon}</span>
          <div class="feature-body">
            <h3 class="feature-title h4">{feature.title}</h3>
            <p class="feature-desc body text-muted">{feature.description}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .features-section {
    background-color: var(--color-background);
    border-top: var(--border-light);
  }

  .features-header {
    margin-block-end: var(--space-64);
  }

  .section-label {
    display: block;
    color: var(--color-muted);
    margin-block-end: var(--space-16);
  }

  .features-title {
    margin-block: 0;
    max-width: 20ch;
  }

  .features-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-2);
  }

  .feature-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-24);
    padding: var(--space-32);
    border-radius: var(--radius-2xl);
    border: var(--border-light);
    background-color: var(--color-surface);
    transition: transform var(--motion-normal), box-shadow var(--motion-normal), border-color var(--motion-fast);
  }

  .feature-card:hover {
    box-shadow: var(--shadow-md);
    transform: translateY(-3px);
    border-color: var(--color-border);
  }

  .feature-icon {
    font-size: var(--text-h2);
    line-height: 1;
    color: var(--color-text-secondary);
  }

  .feature-body {
    display: flex;
    flex-direction: column;
    gap: var(--space-12);
    flex: 1;
  }

  .feature-title {
    margin-block: 0;
    color: var(--color-text-primary);
  }

  .feature-desc {
    margin-block: 0;
    color: var(--color-text-secondary);
  }

  .text-muted { color: var(--color-text-secondary); }

  @media (min-width: 768px) {
    .features-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-16);
    }
  }

  @media (min-width: 1024px) {
    .features-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }
</style>
