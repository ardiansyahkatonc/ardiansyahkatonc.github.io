---
import { getLangFromUrl, useTranslations } from '../../i18n';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const features = [
  { id: 'meeting', icon: '◎' },
  { id: 'knowledge', icon: '▣' },
  { id: 'document', icon: '◈' },
  { id: 'workspace', icon: '⬡' },
] as const;
---
<section class="section section-content features-section" aria-labelledby="features-heading">
  <div class="container-xl">
    <div class="features-header">
      <span class="section-label label">{t('features.label')}</span>
      <h2 id="features-heading" class="features-title h2">{t('features.title')}</h2>
    </div>
    <div class="features-grid">
      {features.map((feature) => (
        <div class="feature-card" id={`feature-${feature.id}`}>
          <span class="feature-icon" aria-hidden="true">{feature.icon}</span>
          <div class="feature-body">
            <h3 class="feature-title h4">{t(`features.${feature.id}.title` as any)}</h3>
            <p class="feature-desc body text-muted">{t(`features.${feature.id}.desc` as any)}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .features-section {
    background-color: var(--color-background);
    border-top: var(--border-light);
  }

  .features-header {
    margin-block-end: var(--space-64);
  }

  .section-label {
    display: block;
    color: var(--color-muted);
    margin-block-end: var(--space-16);
  }

  .features-title {
    margin-block: 0;
    max-width: 20ch;
  }

  .features-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-2);
  }

  .feature-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-24);
    padding: var(--space-32);
    border-radius: var(--radius-2xl);
    border: var(--border-light);
    background-color: var(--color-surface);
    transition: transform var(--motion-normal), box-shadow var(--motion-normal), border-color var(--motion-fast);
  }

  .feature-card:hover {
    box-shadow: var(--shadow-lg);
    transform: translateY(-4px);
    border-color: var(--color-border);
  }

  .feature-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    border-radius: var(--radius-large);
    background: var(--color-accent-light);
    color: var(--color-accent);
    font-size: 1.5rem;
    line-height: 1;
    transition: transform var(--motion-normal), background var(--motion-fast);
  }

  .feature-card:hover .feature-icon {
    transform: scale(1.05);
    background: var(--color-accent-mid);
  }

  .feature-body {
    display: flex;
    flex-direction: column;
    gap: var(--space-12);
    flex: 1;
  }

  .feature-title {
    margin-block: 0;
    color: var(--color-text-primary);
  }

  .feature-desc {
    margin-block: 0;
    color: var(--color-text-secondary);
  }

  .text-muted { color: var(--color-text-secondary); }

  @media (min-width: 768px) {
    .features-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-16);
    }
  }

  @media (min-width: 1024px) {
    .features-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }
</style>
