<section class="section section-content mission-section" aria-labelledby="mission-heading">
  <div class="container-xl">
    <div class="mission-inner">
      <span class="section-label">Why kat.on</span>
      <h2 id="mission-heading" class="mission-title">
        Technology should simplify work, not make it more complicated.
      </h2>
      <p class="mission-text">
        We design AI-native products that help organizations manage knowledge, streamline workflows, and accelerate digital transformation while keeping people at the center of every decision.
      </p>
    </div>
  </div>
</section>

<style>
  .mission-section {
    border-top: var(--border-thin);
    background-color: var(--color-surface);
  }

  .mission-inner {
    max-width: 52rem;
  }

  .section-label {
    display: block;
    font-size: var(--text-label);
    font-weight: var(--weight-medium);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-text-secondary);
    margin-block-end: var(--space-24);
  }

  .mission-title {
    font-size: var(--text-h2);
    font-weight: var(--weight-bold);
    line-height: 1.25;
    letter-spacing: -0.01em;
    color: var(--color-text-primary);
    margin-block: 0 var(--space-16);
  }

  .mission-text {
    font-size: var(--text-body-lg);
    line-height: 1.6;
    color: var(--color-text-secondary);
    margin-block: 0;
  }
</style>
