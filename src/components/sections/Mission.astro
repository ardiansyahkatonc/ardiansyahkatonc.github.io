<section class="section section-content mission-section" aria-labelledby="mission-heading">
  <div class="container-xl">
    <div class="mission-inner">
      <span class="section-label label">Why kat.on</span>
      <h2 id="mission-heading" class="mission-title h2">
        Technology should simplify work, not make it more complicated.
      </h2>
      <p class="mission-text body-lg text-muted">
        We design AI-native products that help organizations manage knowledge, streamline workflows, and accelerate public service delivery while keeping people at the center of every decision.
      </p>
    </div>
  </div>
</section>

<style>
  .mission-section {
    background-color: var(--color-background);
    border-top: var(--border-light);
  }

  .mission-inner {
    max-width: 48rem;
  }

  .section-label {
    display: block;
    color: var(--color-muted);
    margin-block-end: var(--space-24);
  }

  .mission-title {
    margin-block: 0 var(--space-24);
  }

  .text-muted { color: var(--color-text-secondary); }

  .mission-text {
    margin-block: 0;
  }
</style>
