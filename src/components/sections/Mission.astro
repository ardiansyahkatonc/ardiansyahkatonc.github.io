<section class="section-sm mission-section">
  <div class="container">
    <h2 class="mission-title text-sm">Why kat.on</h2>
    <div class="mission-content-wrapper">
      <p class="mission-content">
        Technology should simplify work, not make it more complicated.
      </p>
      <p class="mission-content">
        We design AI-native products that help organizations manage knowledge, streamline workflows, and accelerate digital transformation while keeping people at the center of every decision.
      </p>
    </div>
  </div>
</section>

<style>
  .mission-section {
    border-top: 1px solid var(--color-border);
  }

  .mission-title {
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: var(--space-4);
  }

  .mission-content-wrapper {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .mission-content {
    font-size: var(--text-xl);
    font-weight: var(--font-weight-medium);
    line-height: 1.4;
    max-width: 40ch;
    margin: 0;
  }

  @media (min-width: 768px) {
    .mission-content {
      font-size: var(--text-2xl);
    }
  }
</style>
