---
// =============================================================================
// Logo — the SINGLE, centralized way to render the kat.on & ARIA brand marks.
// No page may use raw <img> tags or hardcoded logo paths — always use <Logo />.
//
// Official source SVGs live in  public/brand/<brand>/logo/ :
//   • public/brand/katon/logo/katon-full.svg   (official kat.on emblem)
//   • public/brand/aria/logo/aria-full.svg     (official ARIA emblem)
//
// kat.on: official emblem + "kat.on" wordmark lockup. The emblem is a dark-navy
// monochrome mark — shown as-is on light surfaces and filtered to light on dark
// (theme-adaptive). ARIA: its self-contained emblem file.
//
//   <Logo />                  kat.on emblem + wordmark (theme-adaptive)
//   <Logo variant="icon" />   kat.on emblem only
//   <Logo brand="aria" />     official ARIA emblem
//   <Logo size="sm|md|lg" />  sizing
// =============================================================================
import { BRAND } from '../../config/brand';

type BrandName = 'katon' | 'aria';
type Variant = 'full' | 'icon' | 'light' | 'dark' | 'monochrome';

interface Props {
  brand?: BrandName;
  variant?: Variant;
  size?: 'sm' | 'md' | 'lg';
  class?: string;
  alt?: string;
}

const { brand = 'katon', variant = 'full', size = 'md', class: className = '', alt } = Astro.props;

const KATON_LOGO = '/brand/katon/logo/katon-full.svg';
const ARIA_LOGO = '/brand/aria/logo/aria-full.svg';

const emblemSizes = { sm: 20, md: 26, lg: 34 } as const;
const ariaSizes = { sm: 28, md: 36, lg: 56 } as const;
const e = emblemSizes[size];
const ariaSize = ariaSizes[size];

const iconOnly = variant === 'icon';
---

{brand === 'aria' ? (
  <img
    src={ARIA_LOGO}
    alt={alt ?? 'ARIA'}
    width={ariaSize}
    height={ariaSize}
    class={`brand-logo brand-logo--aria ${className}`}
    loading="lazy"
    decoding="async"
  />
) : iconOnly ? (
  <img
    src={KATON_LOGO}
    alt={alt ?? BRAND.name}
    width={e}
    height={e}
    class={`katon-emblem ${className}`}
    decoding="async"
  />
) : (
  <span class={`katon-lockup ${className}`} role="img" aria-label={alt ?? BRAND.name}>
    <img
      src={KATON_LOGO}
      alt=""
      aria-hidden="true"
      width={e}
      height={e}
      class="katon-emblem"
      decoding="async"
    />
    <span class="katon-word" style={`font-size:${Math.round(e * 0.72)}px`}>{BRAND.name}</span>
  </span>
)}

<style>
  .katon-lockup {
    display: inline-flex;
    align-items: center;
    gap: 0.42em;
    line-height: 1;
    transition: opacity var(--motion-fast);
  }
  .katon-lockup:hover { opacity: 0.8; }

  .katon-word {
    font-weight: 700;
    letter-spacing: -0.03em;
    color: var(--color-text-primary);
  }

  .katon-emblem {
    display: block;
    flex-shrink: 0;
    /* Dark-navy emblem on light surfaces; inverted to light on dark via the
       theme token (--logo-filter). */
    filter: var(--logo-filter);
    transition: opacity var(--motion-fast), filter var(--motion-fast);
  }
  .katon-emblem:hover { opacity: 0.8; }

  .brand-logo {
    display: block;
    flex-shrink: 0;
    transition: opacity var(--motion-fast);
  }
  .brand-logo:hover { opacity: 0.85; }
  /* ARIA emblem ships with its own dark canvas — round it into a badge with a
     subtle adaptive edge so it stays defined on both light and dark surfaces. */
  .brand-logo--aria {
    border-radius: var(--radius-medium);
    border: 1px solid var(--color-border);
  }
</style>
